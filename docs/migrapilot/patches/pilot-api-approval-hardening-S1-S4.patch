+/**
+ * Approve a pending request. Validates state/expiry/separation-of-duties, then
+ * transitions PENDING→APPROVED atomically (CAS via updateMany) so two concurrent
+ * approvals cannot both succeed. Returns the approval and a fresh token.
+ */
+export async function approveApprovalRequest(input: { approvalId: string; approverId: string }) {
+  const approval = await prisma.pilotApproval.findUnique({ where: { id: input.approvalId } });
+  if (!approval) throw new ApprovalError("NOT_FOUND", 404, "Approval not found");
+
+  assertApprovable(approval, input.approverId, selfApprovalAllowed());
+
+  const cas = await prisma.pilotApproval.updateMany({
+    where: { id: approval.id, status: "PENDING" },
+    data: { status: "APPROVED", approvedBy: input.approverId }
+  });
+  if (cas.count !== 1) {
+    throw new ApprovalError("INVALID_STATE", 409, "Approval is no longer PENDING");
+  }
+
+  const approved = await prisma.pilotApproval.findUnique({ where: { id: approval.id } });
+  if (!approved) throw new ApprovalError("NOT_FOUND", 404, "Approval not found");
+
+  const approvalToken = mintApprovalToken({
+    approvalId: approved.id,
+    argsHash: approved.argsHash,
+    expiresAt: approved.expiresAt.toISOString()
+  });
+  return { approval: approved, approvalToken };
+}
+
+/**
+ * Deny a pending request. Only a PENDING request may be denied.
+ */
+export async function denyApprovalRequest(input: { approvalId: string; approverId: string }) {
+  const approval = await prisma.pilotApproval.findUnique({ where: { id: input.approvalId } });
+  if (!approval) throw new ApprovalError("NOT_FOUND", 404, "Approval not found");
+  if (approval.status !== "PENDING") {
+    throw new ApprovalError("INVALID_STATE", 409, `Approval is ${approval.status}, not PENDING`);
+  }
+
+  const cas = await prisma.pilotApproval.updateMany({
+    where: { id: approval.id, status: "PENDING" },
+    data: { status: "DENIED", approvedBy: input.approverId }
+  });
+  if (cas.count !== 1) {
+    throw new ApprovalError("INVALID_STATE", 409, "Approval is no longer PENDING");
+  }
+
+  const denied = await prisma.pilotApproval.findUnique({ where: { id: approval.id } });
+  if (!denied) throw new ApprovalError("NOT_FOUND", 404, "Approval not found");
+  return { approval: denied };
+}
