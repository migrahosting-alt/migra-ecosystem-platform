+import { afterEach, beforeEach, describe, expect, it } from "vitest";
+
+import {
+  ApprovalError,
+  assertApprovable,
+  mintApprovalToken,
+  selfApprovalAllowed,
+  verifyApprovalToken
+} from "./approvalService.js";
+
+const ENV_KEYS = [
+  "APPROVAL_SIGNING_SECRET",
+  "PILOT_ALLOW_SELF_APPROVAL",
+  "PILOT_REQUIRE_AUTH",
+  "APP_ENV",
+  "NODE_ENV"
+] as const;
+
+let saved: Record<string, string | undefined>;
+
+beforeEach(() => {
+  saved = {};
+  for (const k of ENV_KEYS) saved[k] = process.env[k];
+});
+
+afterEach(() => {
+  for (const k of ENV_KEYS) {
+    if (saved[k] === undefined) delete process.env[k];
+    else process.env[k] = saved[k];
+  }
+});
+
+function approval(overrides: Partial<{ status: string; expiresAt: Date; requestedBy: string }> = {}) {
+  return {
+    status: "PENDING",
+    expiresAt: new Date(Date.now() + 60_000),
+    requestedBy: "alice",
+    ...overrides
+  };
+}
+
+describe("assertApprovable (S1: separation of duties + state/expiry)", () => {
+  it("accepts a pending, unexpired approval from a different approver", () => {
+    expect(() => assertApprovable(approval(), "bob", false)).not.toThrow();
+  });
+
+  it("rejects an already-decided approval", () => {
+    expect(() => assertApprovable(approval({ status: "APPROVED" }), "bob", false))
+      .toThrowError(/not PENDING/);
+    try {
+      assertApprovable(approval({ status: "DENIED" }), "bob", false);
+    } catch (e) {
+      expect((e as ApprovalError).code).toBe("INVALID_STATE");
+      expect((e as ApprovalError).httpStatus).toBe(409);
+    }
+  });
+
+  it("rejects an expired approval", () => {
+    try {
+      assertApprovable(approval({ expiresAt: new Date(Date.now() - 1000) }), "bob", false);
+      throw new Error("should have thrown");
+    } catch (e) {
+      expect((e as ApprovalError).code).toBe("EXPIRED");
+    }
+  });
+
+  it("blocks self-approval when not allowed", () => {
+    try {
+      assertApprovable(approval({ requestedBy: "alice" }), "alice", false);
+      throw new Error("should have thrown");
+    } catch (e) {
+      expect((e as ApprovalError).code).toBe("SELF_APPROVAL_FORBIDDEN");
+      expect((e as ApprovalError).httpStatus).toBe(403);
+    }
+  });
+
+  it("permits self-approval when explicitly allowed", () => {
+    expect(() => assertApprovable(approval({ requestedBy: "alice" }), "alice", true)).not.toThrow();
+  });
+});
+
+describe("selfApprovalAllowed", () => {
+  it("is allowed in dev without auth required", () => {
+    delete process.env.APP_ENV;
+    process.env.NODE_ENV = "development";
+    delete process.env.PILOT_REQUIRE_AUTH;
+    delete process.env.PILOT_ALLOW_SELF_APPROVAL;
+    expect(selfApprovalAllowed()).toBe(true);
+  });
+
+  it("is forbidden in production by default", () => {
+    process.env.NODE_ENV = "production";
+    delete process.env.PILOT_ALLOW_SELF_APPROVAL;
+    expect(selfApprovalAllowed()).toBe(false);
+  });
+
+  it("is forbidden when auth is required, even in dev", () => {
+    process.env.NODE_ENV = "development";
+    process.env.PILOT_REQUIRE_AUTH = "true";
+    delete process.env.PILOT_ALLOW_SELF_APPROVAL;
+    expect(selfApprovalAllowed()).toBe(false);
+  });
+
+  it("honors explicit opt-in", () => {
+    process.env.NODE_ENV = "production";
+    process.env.PILOT_ALLOW_SELF_APPROVAL = "true";
+    expect(selfApprovalAllowed()).toBe(true);
+  });
+});
+
+describe("token signing (S2: fail closed on missing secret in prod)", () => {
+  const payload = { approvalId: "a1", argsHash: "h1", expiresAt: new Date(Date.now() + 60_000).toISOString() };
+
+  it("round-trips a token when a secret is configured", () => {
+    process.env.APPROVAL_SIGNING_SECRET = "test-secret";
+    const token = mintApprovalToken(payload);
+    expect(verifyApprovalToken(token)).toMatchObject({ approvalId: "a1", argsHash: "h1" });
+  });
+
+  it("rejects a tampered signature", () => {
+    process.env.APPROVAL_SIGNING_SECRET = "test-secret";
+    const token = mintApprovalToken(payload);
+    const forged = token.split(".")[0] + ".deadbeef";
+    expect(() => verifyApprovalToken(forged)).toThrowError(/Invalid approval signature/);
+  });
+
+  it("throws in production when the signing secret is unset", () => {
+    process.env.NODE_ENV = "production";
+    delete process.env.APP_ENV;
+    delete process.env.APPROVAL_SIGNING_SECRET;
+    try {
+      mintApprovalToken(payload);
+      throw new Error("should have thrown");
+    } catch (e) {
+      expect((e as ApprovalError).code).toBe("SIGNING_SECRET_MISSING");
+    }
+  });
+
+  it("allows the dev fallback secret outside production", () => {
+    process.env.NODE_ENV = "development";
+    delete process.env.APP_ENV;
+    delete process.env.APPROVAL_SIGNING_SECRET;
+    expect(() => mintApprovalToken(payload)).not.toThrow();
+  });
+});
