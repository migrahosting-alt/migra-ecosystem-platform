+import { describe, expect, it, vi } from "vitest";
+import type { ToolRisk } from "@migra/tooling";
+
+import {
+  computeTaskActionLevel,
+  decideTaskExecution,
+  executeMissionTask,
+  nextTaskStatus,
+  type ExecTask,
+  type ExecContext,
+  type ExecDeps,
+} from "./missionExecutor.js";
+
+const RISK: Record<string, ToolRisk> = {
+  "repo.readFile": "READ",
+  "repo.applyPatch": "WRITE",
+  "repo.command": "WRITE",
+  "pods.delete": "DANGER",
+  "dns.createRecord": "WRITE",
+};
+
+function task(over: Partial<ExecTask> = {}): ExecTask {
+  return { taskId: "t1", toolCalls: [], retries: 0, maxRetries: 2, ...over };
+}
+
+function ctx(over: Partial<ExecContext> = {}): ExecContext {
+  return {
+    environment: "local",
+    identityOk: true,
+    approvalGranted: false,
+    remoteMutationEnabled: false,
+    level6GatesMet: false,
+    remoteReadAllowed: true,
+    cancelled: false,
+    riskOf: (n) => RISK[n],
+    ...over,
+  };
+}
+
+function deps(over: Partial<ExecDeps> = {}): ExecDeps {
+  return {
+    now: () => 1_000,
+    isCancelled: async () => false,
+    timeoutMs: 50,
+    runTool: async () => ({ ok: true }),
+    record: async () => {},
+    ...over,
+  };
+}
+
+describe("action-level classification", () => {
+  it("local read = L0, remote read = L5", () => {
+    expect(computeTaskActionLevel(task({ toolCalls: [{ toolName: "repo.readFile", input: {} }] }), ctx())).toBe(0);
+    expect(computeTaskActionLevel(task({ toolCalls: [{ toolName: "repo.readFile", input: {}, environment: "prod" }] }), ctx())).toBe(5);
+  });
+  it("local write = L2, remote write = L6, danger local = L3", () => {
+    expect(computeTaskActionLevel(task({ toolCalls: [{ toolName: "repo.applyPatch", input: {} }] }), ctx())).toBe(2);
+    expect(computeTaskActionLevel(task({ toolCalls: [{ toolName: "dns.createRecord", input: {}, environment: "prod" }] }), ctx())).toBe(6);
+    expect(computeTaskActionLevel(task({ toolCalls: [{ toolName: "pods.delete", input: {} }] }), ctx())).toBe(3);
+  });
+  it("unknown tool тЖТ undefined (fail closed)", () => {
+    expect(computeTaskActionLevel(task({ toolCalls: [{ toolName: "nope.unknown", input: {} }] }), ctx())).toBeUndefined();
+  });
+});
+
+describe("decideTaskExecution тАФ the 16 mission scenarios (decision layer)", () => {
+  it("1. read-only mission тЖТ execute (no approval)", () => {
+    const d = decideTaskExecution(task({ toolCalls: [{ toolName: "repo.readFile", input: {} }] }), ctx());
+    expect(d).toEqual({ kind: "execute", level: 0, dryRun: false });
+  });
+  it("2. draft-only mission (no tool calls) тЖТ skip", () => {
+    expect(decideTaskExecution(task({ toolCalls: [] }), ctx()).kind).toBe("skip");
+  });
+  it("3. local-write mission with no approval тЖТ await_approval", () => {
+    const d = decideTaskExecution(task({ toolCalls: [{ toolName: "repo.applyPatch", input: {} }] }), ctx());
+    expect(d.kind).toBe("await_approval");
+  });
+  it("4. local-command mission with no approval тЖТ await_approval", () => {
+    const d = decideTaskExecution(task({ toolCalls: [{ toolName: "pods.delete", input: {} }] }), ctx());
+    expect(d.kind).toBe("await_approval");
+  });
+  it("5. denied remote mutation (disabled by default)", () => {
+    const d = decideTaskExecution(
+      task({ toolCalls: [{ toolName: "dns.createRecord", input: {}, environment: "prod" }] }),
+      ctx({ approvalGranted: true })
+    );
+    expect(d).toMatchObject({ kind: "denied", code: "REMOTE_MUTATION_DISABLED" });
+  });
+  it("6. approved safe local write тЖТ execute", () => {
+    const d = decideTaskExecution(task({ toolCalls: [{ toolName: "repo.applyPatch", input: {} }] }), ctx({ approvalGranted: true }));
+    expect(d).toEqual({ kind: "execute", level: 2, dryRun: false });
+  });
+  it("11. stale/absent approval тЖТ await_approval (fail safe)", () => {
+    // approvalGranted:false models a stale/expired approval
+    expect(decideTaskExecution(task({ toolCalls: [{ toolName: "repo.command", input: {} }] }), ctx()).kind).toBe("await_approval");
+  });
+  it("12. missing identity/config тЖТ denied (fail closed)", () => {
+    const d = decideTaskExecution(task({ toolCalls: [{ toolName: "repo.readFile", input: {} }] }), ctx({ identityOk: false }));
+    expect(d).toMatchObject({ kind: "denied", code: "IDENTITY_MISSING" });
+  });
+  it("13. action-level mismatch тАФ remote write without gates тЖТ denied", () => {
+    const d = decideTaskExecution(
+      task({ toolCalls: [{ toolName: "dns.createRecord", input: {}, environment: "prod" }] }),
+      ctx({ remoteMutationEnabled: true, level6GatesMet: false, approvalGranted: true })
+    );
+    expect(d).toMatchObject({ kind: "denied", code: "LEVEL6_GATES_UNMET" });
+  });
+  it("remote write with ALL gates + approval тЖТ execute", () => {
+    const d = decideTaskExecution(
+      task({ toolCalls: [{ toolName: "dns.createRecord", input: {}, environment: "prod" }] }),
+      ctx({ remoteMutationEnabled: true, level6GatesMet: true, approvalGranted: true })
+    );
+    expect(d).toEqual({ kind: "execute", level: 6, dryRun: false });
+  });
+});
+
+describe("nextTaskStatus тАФ deterministic state machine", () => {
+  it("cancel тЖТ skipped, skip тЖТ done, approval тЖТ awaiting_approval, success тЖТ done", () => {
+    expect(nextTaskStatus(task(), { type: "cancelled" })).toBe("skipped");
+    expect(nextTaskStatus(task(), { type: "skipped" })).toBe("done");
+    expect(nextTaskStatus(task(), { type: "await_approval" })).toBe("awaiting_approval");
+    expect(nextTaskStatus(task(), { type: "succeeded" })).toBe("done");
+  });
+  it("8. retriable failure with budget тЖТ pending (retry); exhausted тЖТ failed", () => {
+    expect(nextTaskStatus(task({ retries: 0, maxRetries: 2 }), { type: "failed", retriable: true })).toBe("pending");
+    expect(nextTaskStatus(task({ retries: 2, maxRetries: 2 }), { type: "failed", retriable: true })).toBe("failed");
+  });
+  it("non-retriable failure тЖТ failed; nonCritical тЖТ skipped", () => {
+    expect(nextTaskStatus(task(), { type: "failed", retriable: false })).toBe("failed");
+    expect(nextTaskStatus(task({ nonCritical: true }), { type: "failed", retriable: false })).toBe("skipped");
+    expect(nextTaskStatus(task({ nonCritical: true }), { type: "denied" })).toBe("skipped");
+  });
+});
+
+describe("executeMissionTask тАФ orchestration with fakes", () => {
+  it("16. successful completion runs every tool call and records each", async () => {
+    const record = vi.fn(async () => {});
+    const runTool = vi.fn(async () => ({ ok: true }));
+    const t = task({ toolCalls: [{ toolName: "repo.readFile", input: {} }, { toolName: "repo.readFile", input: {} }] });
+    const r = await executeMissionTask(t, "m1", ctx(), deps({ runTool, record }));
+    expect(r.status).toBe("done");
+    expect(r.ranToolCalls).toBe(2);
+    expect(record).toHaveBeenCalledTimes(2);
