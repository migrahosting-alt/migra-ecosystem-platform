+/**
+ * Mission Executor (Thread 2) тАФ turns a planned mission task into controlled,
+ * auditable execution. Replaces the missionWorker stub that marked tasks done
+ * without running anything.
+ *
+ * Design:
+ *  - Pure decision layer (`decideTaskExecution`, `computeTaskActionLevel`,
+ *    `nextTaskStatus`) with no I/O тАФ fully unit-testable and deterministic.
+ *  - `executeMissionTask` orchestrates the decision тЖТ tool-runner execution тЖТ
+ *    persistence, with injected dependencies (clock, cancellation, tool runner,
+ *    recorder) so it is testable with fakes and free of hidden side effects.
+ *
+ * SAFETY (action-level model):
+ *   L0 remote/local READ  тЖТ execute (reads are safe)
+ *   L1 draft / dry-run    тЖТ execute as dry-run
+ *   L2 local WRITE        тЖТ requires approval
+ *   L3 local command      тЖТ requires approval
+ *   L5 remote READ        тЖТ requires policy allow
+ *   L6 remote WRITE/DANGERтЖТ DISABLED unless every Level-6 gate passes AND approved
+ *   Missing identity / config тЖТ fail closed (denied).
+ */
+
+import type { ToolRisk } from "@migra/tooling";
+
+export type ActionLevel = 0 | 1 | 2 | 3 | 5 | 6;
+
+export type MissionTaskStatus =
+  | "pending"
+  | "running"
+  | "done"
+  | "failed"
+  | "awaiting_approval"
+  | "skipped";
+
+export interface ExecToolCall {
+  toolName: string;
+  input: Record<string, unknown>;
+  environment?: string; // "local" | "staging" | "prod" | ...
+  nonCritical?: boolean;
+}
+
+export interface ExecTask {
+  taskId: string;
+  toolCalls: ExecToolCall[];
+  retries: number;
+  maxRetries: number;
+  nonCritical?: boolean;
+}
+
+export interface ExecContext {
+  /** resolved mission environment */
+  environment: string;
+  /** operator/mission identity is present and valid */
+  identityOk: boolean;
+  /** an approval has been granted for this mission/task */
+  approvalGranted: boolean;
+  /** remote (Level 6) mutation is enabled by config (default false) */
+  remoteMutationEnabled: boolean;
+  /** every Level-6 gate (target verify, rollback, secrets, etc.) is satisfied */
+  level6GatesMet: boolean;
+  /** policy allows remote reads (Level 5) */
+  remoteReadAllowed: boolean;
+  /** mission/task has been cancelled */
+  cancelled: boolean;
+  /** lookup a tool's declared risk; undefined = unknown tool */
+  riskOf: (toolName: string) => ToolRisk | undefined;
+}
+
+export type Decision =
+  | { kind: "cancel" }
+  | { kind: "skip"; reason: string }
+  | { kind: "await_approval"; level: ActionLevel; reason: string }
+  | { kind: "denied"; code: string; reason: string }
+  | { kind: "execute"; level: ActionLevel; dryRun: boolean };
+
+const REMOTE_ENVS = new Set(["prod", "production", "staging", "remote"]);
+
+export function isRemoteEnv(environment: string | undefined): boolean {
+  return environment != null && REMOTE_ENVS.has(environment.toLowerCase());
+}
+
+/**
+ * The action level required to run this task = the max over its tool calls.
+ * Returns undefined if any tool is unknown (fail closed upstream).
+ */
+export function computeTaskActionLevel(task: ExecTask, ctx: ExecContext): ActionLevel | undefined {
+  let level: ActionLevel = 0;
+  for (const call of task.toolCalls) {
+    const risk = ctx.riskOf(call.toolName);
+    if (risk === undefined) return undefined; // unknown tool тЖТ fail closed
+    const remote = isRemoteEnv(call.environment ?? ctx.environment);
+    let callLevel: ActionLevel;
+    if (risk === "READ") {
+      callLevel = remote ? 5 : 0;
+    } else if (risk === "WRITE") {
+      callLevel = remote ? 6 : 2;
+    } else {
+      // DANGER
+      callLevel = remote ? 6 : 3;
+    }
+    if (callLevel > level) level = callLevel;
+  }
+  return level;
+}
+
+/**
+ * Pure execution decision. No I/O.
+ */
+export function decideTaskExecution(task: ExecTask, ctx: ExecContext): Decision {
+  if (ctx.cancelled) return { kind: "cancel" };
+  if (!ctx.identityOk) {
+    return { kind: "denied", code: "IDENTITY_MISSING", reason: "Mission identity is missing or invalid" };
+  }
+  if (task.toolCalls.length === 0) {
+    return { kind: "skip", reason: "No tool calls тАФ draft/read-only task" };
+  }
+
+  const level = computeTaskActionLevel(task, ctx);
+  if (level === undefined) {
+    return { kind: "denied", code: "UNKNOWN_TOOL", reason: "Task references an unknown tool" };
+  }
+
+  switch (level) {
+    case 0:
+      return { kind: "execute", level, dryRun: false }; // local read
+    case 1:
+      return { kind: "execute", level, dryRun: true };
+    case 2:
+    case 3:
+      return ctx.approvalGranted
+        ? { kind: "execute", level, dryRun: false }
+        : { kind: "await_approval", level, reason: "Local write/command requires approval" };
+    case 5:
+      return ctx.remoteReadAllowed
+        ? { kind: "execute", level, dryRun: false }
+        : { kind: "denied", code: "REMOTE_READ_BLOCKED", reason: "Remote read not permitted by policy" };
+    case 6:
+      if (!ctx.remoteMutationEnabled) {
+        return { kind: "denied", code: "REMOTE_MUTATION_DISABLED", reason: "Remote mutation is disabled by default" };
+      }
+      if (!ctx.level6GatesMet) {
+        return { kind: "denied", code: "LEVEL6_GATES_UNMET", reason: "Level-6 gates not satisfied" };
+      }
+      if (!ctx.approvalGranted) {
+        return { kind: "await_approval", level, reason: "Remote mutation requires approval" };
+      }
+      return { kind: "execute", level, dryRun: false };
+    default:
+      return { kind: "denied", code: "UNCLASSIFIED", reason: `Unclassified action level ${level}` };
+  }
+}
+
+/**
+ * Deterministic task state transition given an execution outcome.
+ */
+export type TaskOutcome =
+  | { type: "cancelled" }
+  | { type: "skipped" }
+  | { type: "await_approval" }
+  | { type: "denied" }
+  | { type: "succeeded" }
+  | { type: "failed"; retriable: boolean };
+
+export function nextTaskStatus(
+  task: Pick<ExecTask, "retries" | "maxRetries" | "nonCritical">,
+  outcome: TaskOutcome
+): MissionTaskStatus {
+  switch (outcome.type) {
+    case "cancelled":
+      return "skipped";
+    case "skipped":
+      return "done";
+    case "await_approval":
+      return "awaiting_approval";
+    case "denied":
+      return task.nonCritical ? "skipped" : "failed";
+    case "succeeded":
+      return "done";
+    case "failed":
+      // Retriable and budget remaining тЖТ back to pending for another attempt.
+      if (outcome.retriable && task.retries < task.maxRetries) return "pending";
+      return task.nonCritical ? "skipped" : "failed";
+  }
+}
+
+/* тФАтФА Orchestration тФАтФА */
+
+export interface ExecDeps {
+  now: () => number;
+  isCancelled: () => Promise<boolean>;
+  /** run one tool call; returns ok + optional error/journal */
+  runTool: (call: ExecToolCall, opts: { dryRun: boolean; idempotencyKey: string; timeoutMs: number }) => Promise<{
+    ok: boolean;
+    errorCode?: string;
+    journalEntryId?: string;
+    data?: unknown;
+  }>;
+  /** persist a tool run + emit audit (redacted upstream) */
+  record: (entry: {
+    taskId: string;
+    toolName: string;
+    level: ActionLevel;
+    dryRun: boolean;
+    ok: boolean;
+    errorCode?: string;
+    journalEntryId?: string;
+  }) => Promise<void>;
+  timeoutMs: number;
+}
+
+export interface TaskExecutionResult {
+  status: MissionTaskStatus;
+  decision: Decision;
+  ranToolCalls: number;
+  attempts: number;
+}
+
+/**
+ * Execute a single mission task. Bounded, cancellable, idempotent, audited.
+ */
+export async function executeMissionTask(
+  task: ExecTask,
+  missionId: string,
+  ctx: ExecContext,
+  deps: ExecDeps
+): Promise<TaskExecutionResult> {
+  const decision = decideTaskExecution(task, ctx);
+
+  if (decision.kind === "cancel") {
+    return { status: nextTaskStatus(task, { type: "cancelled" }), decision, ranToolCalls: 0, attempts: task.retries };
+  }
+  if (decision.kind === "skip") {
+    return { status: nextTaskStatus(task, { type: "skipped" }), decision, ranToolCalls: 0, attempts: task.retries };
+  }
+  if (decision.kind === "await_approval") {
+    return { status: nextTaskStatus(task, { type: "await_approval" }), decision, ranToolCalls: 0, attempts: task.retries };
+  }
+  if (decision.kind === "denied") {
+    return { status: nextTaskStatus(task, { type: "denied" }), decision, ranToolCalls: 0, attempts: task.retries };
+  }
+
+  // decision.kind === "execute"
+  const attempt = task.retries + 1;
+  let ranToolCalls = 0;
+  let failed: { retriable: boolean } | null = null;
+
+  for (const call of task.toolCalls) {
+    // Cancellation is checked before every tool call тАФ never mid-mutation.
+    if (await deps.isCancelled()) {
+      return { status: nextTaskStatus(task, { type: "cancelled" }), decision, ranToolCalls, attempts: attempt };
+    }
+
+    const idempotencyKey = `${missionId}:${task.taskId}:${call.toolName}:${attempt}`;
+    let res: Awaited<ReturnType<ExecDeps["runTool"]>>;
+    try {
+      res = await withTimeout(
+        deps.runTool(call, { dryRun: decision.dryRun, idempotencyKey, timeoutMs: deps.timeoutMs }),
+        deps.timeoutMs,
+        deps.now
+      );
+    } catch (err) {
+      res = { ok: false, errorCode: err instanceof TimeoutError ? "TIMEOUT" : "EXECUTION_ERROR" };
+    }
+    ranToolCalls++;
+
+    await deps.record({
+      taskId: task.taskId,
+      toolName: call.toolName,
+      level: decision.level,
+      dryRun: decision.dryRun,
+      ok: res.ok,
+      errorCode: res.errorCode,
+      journalEntryId: res.journalEntryId,
+    });
+
+    if (!res.ok) {
+      // A critical tool failure aborts the task; a nonCritical one is tolerated.
+      if (call.nonCritical) continue;
+      failed = { retriable: res.errorCode === "TIMEOUT" || res.errorCode === "EXECUTION_ERROR" };
+      break;
+    }
+  }
+
+  if (failed) {
+    return { status: nextTaskStatus(task, { type: "failed", retriable: failed.retriable }), decision, ranToolCalls, attempts: attempt };
+  }
+  return { status: nextTaskStatus(task, { type: "succeeded" }), decision, ranToolCalls, attempts: attempt };
+}
+
+/* тФАтФА timeout helper тФАтФА */
+
+export class TimeoutError extends Error {
+  constructor() {
+    super("tool execution timed out");
+    this.name = "TimeoutError";
+  }
+}
+
+function withTimeout<T>(p: Promise<T>, timeoutMs: number, now: () => number): Promise<T> {
+  return new Promise<T>((resolve, reject) => {
+    let settled = false;
+    const timer = setTimeout(() => {
+      if (!settled) {
+        settled = true;
+        reject(new TimeoutError());
+      }
+    }, timeoutMs);
+    // `now` is accepted for deterministic test injection; unref the timer so it
+    // never keeps the worker process alive.
+    if (typeof (timer as any).unref === "function") (timer as any).unref();
+    p.then(
+      (v) => { if (!settled) { settled = true; clearTimeout(timer); resolve(v); } },
+      (e) => { if (!settled) { settled = true; clearTimeout(timer); reject(e); } }
+    );
+  });
+}
