+export const REQUIRED_PROD_ACTION_LEVEL: string;
+export function isProductionEnv(env?: Record<string, string | undefined>): boolean;
+export function missingProductionGates(env?: Record<string, string | undefined>): string[];
+export function assertProductionMigrationGates(
+  env?: Record<string, string | undefined>
+): { enforced: boolean; env: string; missing: string[] };
