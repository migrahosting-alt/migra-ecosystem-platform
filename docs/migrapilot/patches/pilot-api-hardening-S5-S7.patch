+/**
+ * Production migration guard (finding S7).
+ *
+ * `prisma migrate deploy` mutates the production database schema. This guard is
+ * fail-closed: in a production environment the migration is blocked unless every
+ * required gate is satisfied. Non-production environments (dev/staging) are not
+ * gated so normal iteration keeps working.
+ *
+ * Gates required in production:
+ *   - explicit production recognition   (OPS_ENV/NODE_ENV = prod|production)
+ *   - explicit approval                 (GO_LIVE_APPROVED_BY or GO_LIVE_APPROVAL_TOKEN)
+ *   - correct action level              (GO_LIVE_ACTION_LEVEL = 6 — remote mutation)
+ *   - explicit confirmation             (GO_LIVE_CONFIRM = 1 — prevents accidental/default runs)
+ *   - target verification               (BASE_URL set + STRICT or CANARY preflight)
+ *   - rollback plan                     (GO_LIVE_ROLLBACK_PLAN)
+ *   - required secrets/config           (DATABASE_URL, APPROVAL_SIGNING_SECRET)
+ */
+
+export const REQUIRED_PROD_ACTION_LEVEL = "6";
+
+export function isProductionEnv(env = process.env) {
+  const name = (env.OPS_ENV ?? env.NODE_ENV ?? "staging").toLowerCase();
+  return name === "prod" || name === "production";
+}
+
+/**
+ * Returns the list of missing gate descriptions (empty array = all satisfied).
+ * Pure — does not read process.env unless you pass it.
+ */
+export function missingProductionGates(env = process.env) {
+  const missing = [];
+
+  if (!env.GO_LIVE_APPROVED_BY && !env.GO_LIVE_APPROVAL_TOKEN) {
+    missing.push("explicit approval (GO_LIVE_APPROVED_BY or GO_LIVE_APPROVAL_TOKEN)");
+  }
+  if (env.GO_LIVE_ACTION_LEVEL !== REQUIRED_PROD_ACTION_LEVEL) {
+    missing.push(`action level (GO_LIVE_ACTION_LEVEL=${REQUIRED_PROD_ACTION_LEVEL})`);
+  }
+  if (env.GO_LIVE_CONFIRM !== "1") {
+    missing.push("explicit confirmation (GO_LIVE_CONFIRM=1)");
+  }
+  if (!env.BASE_URL) {
+    missing.push("target verification (BASE_URL)");
+  }
+  if (env.STRICT !== "1" && env.OPS_STRICT !== "1" && env.CANARY !== "1") {
+    missing.push("preflight (STRICT=1 or CANARY=1)");
+  }
+  if (!env.GO_LIVE_ROLLBACK_PLAN) {
+    missing.push("rollback plan (GO_LIVE_ROLLBACK_PLAN)");
+  }
+  if (!env.DATABASE_URL) {
+    missing.push("database config (DATABASE_URL)");
+  }
+  if (!env.APPROVAL_SIGNING_SECRET) {
+    missing.push("signing secret (APPROVAL_SIGNING_SECRET)");
+  }
+
+  return missing;
+}
+
+/**
+ * Fail-closed assertion. Throws in production when any gate is missing.
+ * Returns { enforced, env } describing what it decided.
+ */
+export function assertProductionMigrationGates(env = process.env) {
+  const name = (env.OPS_ENV ?? env.NODE_ENV ?? "staging").toLowerCase();
+  if (!isProductionEnv(env)) {
+    return { enforced: false, env: name, missing: [] };
+  }
+
+  const missing = missingProductionGates(env);
+  if (missing.length > 0) {
+    throw new Error(
+      "PRODUCTION MIGRATION BLOCKED (S7) — missing required gates:\n  - " + missing.join("\n  - ")
+    );
+  }
+  return { enforced: true, env: name, missing: [] };
+}
