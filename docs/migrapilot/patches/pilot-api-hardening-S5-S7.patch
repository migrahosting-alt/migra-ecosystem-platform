+/**
+ * Execution mode resolution (finding S6).
+ *
+ * Guarantees that a mutating tool can NEVER silently default to live execution.
+ * Live mutation requires the caller to explicitly set `dryRun: false`; a missing
+ * or ambiguous value fails safe (dry-run) for mutating tools, and a malformed
+ * value fails closed.
+ *
+ * This does not replace the approval / action-level gate — it only decides
+ * whether the call is a live mutation or a dry-run preview. Approval still
+ * applies to live mutations downstream.
+ */
+
+export class ExecutionModeError extends Error {
+  public readonly code = "EXECUTION_MODE_INVALID";
+  constructor(message: string) {
+    super(message);
+    this.name = "ExecutionModeError";
+  }
+}
+
+export interface ExecutionMode {
+  dryRun: boolean;
+  /** true when we forced dry-run because a mutating call omitted an explicit mode */
+  defaultedSafe: boolean;
+}
+
+/**
+ * @param rawDryRun   the caller-supplied dryRun value (may be anything)
+ * @param isMutating  whether the tool is WRITE/DANGER
+ * @param dryRunDefault the entry-point default (only consulted for read tools)
+ */
+export function resolveExecutionMode(
+  rawDryRun: unknown,
+  isMutating: boolean,
+  dryRunDefault: boolean
+): ExecutionMode {
+  // Explicit boolean always wins.
+  if (rawDryRun === true) return { dryRun: true, defaultedSafe: false };
+  if (rawDryRun === false) return { dryRun: false, defaultedSafe: false };
+
+  // Present but not a boolean → malformed. Fail closed for mutating tools;
+  // for read tools it is harmless, fall back to the entry-point default.
+  if (rawDryRun !== undefined && rawDryRun !== null) {
+    if (isMutating) {
+      throw new ExecutionModeError(
+        "dryRun must be an explicit boolean for a mutating tool (received " + typeof rawDryRun + ")"
+      );
+    }
+    return { dryRun: dryRunDefault, defaultedSafe: false };
+  }
+
+  // Missing/null: a mutating tool must NEVER inherit a live default.
+  if (isMutating) return { dryRun: true, defaultedSafe: true };
+
+  // Read tool: dryRun is a no-op; inherit the entry-point default.
+  return { dryRun: dryRunDefault, defaultedSafe: false };
+}
