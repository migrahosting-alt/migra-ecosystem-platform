+import { describe, expect, it } from "vitest";
+
+import { resolveExecutionMode, ExecutionModeError } from "./executionMode.js";
+
+describe("resolveExecutionMode (S6: no silent default to live)", () => {
+  it("honors an explicit dryRun:true", () => {
+    expect(resolveExecutionMode(true, true, false)).toEqual({ dryRun: true, defaultedSafe: false });
+  });
+
+  it("honors an explicit dryRun:false (live opt-in) for a mutating tool", () => {
+    expect(resolveExecutionMode(false, true, true)).toEqual({ dryRun: false, defaultedSafe: false });
+  });
+
+  it("forces dry-run when a mutating tool omits the mode, ignoring a live default", () => {
+    // dryRunDefault=false (live) must NOT leak through for a mutating tool
+    expect(resolveExecutionMode(undefined, true, false)).toEqual({ dryRun: true, defaultedSafe: true });
+    expect(resolveExecutionMode(null, true, false)).toEqual({ dryRun: true, defaultedSafe: true });
+  });
+
+  it("rejects a malformed mode for a mutating tool (fail closed)", () => {
+    expect(() => resolveExecutionMode("false", true, false)).toThrow(ExecutionModeError);
+    expect(() => resolveExecutionMode(0, true, false)).toThrow(ExecutionModeError);
+    expect(() => resolveExecutionMode({}, true, false)).toThrow(/must be an explicit boolean/);
+  });
+
+  it("treats dryRun as a no-op for read tools (inherits entry default)", () => {
+    expect(resolveExecutionMode(undefined, false, false)).toEqual({ dryRun: false, defaultedSafe: false });
+    expect(resolveExecutionMode("nonsense", false, true)).toEqual({ dryRun: true, defaultedSafe: false });
+  });
+});
