+import { describe, expect, it } from "vitest";
+
+import {
+  applyPrivilegedOverrides,
+  isPrivilegedRole,
+  type PolicyViolation
+} from "./safetyPolicy.js";
+
+const overridableBlock: PolicyViolation = { code: "DENIED_DOMAIN", message: "internal domain", severity: "block" };
+const hardBucketBlock: PolicyViolation = { code: "DENIED_BUCKET", message: "secrets bucket", severity: "block" };
+const hardTenantBlock: PolicyViolation = { code: "TENANT_MISMATCH", message: "cross tenant", severity: "block" };
+
+function codes(vs: PolicyViolation[]) {
+  return vs.map((v) => `${v.code}:${v.severity}${v.overridden ? ":overridden" : ""}`);
+}
+
+describe("isPrivilegedRole (S5)", () => {
+  it("only owner and superadmin are privileged", () => {
+    expect(isPrivilegedRole("owner")).toBe(true);
+    expect(isPrivilegedRole("superadmin")).toBe(true);
+    expect(isPrivilegedRole("admin")).toBe(false);
+    expect(isPrivilegedRole("operator")).toBe(false);
+    expect(isPrivilegedRole(undefined)).toBe(false);
+  });
+});
+
+describe("applyPrivilegedOverrides (S5: no accidental universal bypass)", () => {
+  const all = [overridableBlock, hardBucketBlock, hardTenantBlock];
+
+  it("normal user: overrides are ignored, everything stays blocked", () => {
+    expect(codes(applyPrivilegedOverrides(all, "operator", true))).toEqual([
+      "DENIED_DOMAIN:block",
+      "DENIED_BUCKET:block",
+      "TENANT_MISMATCH:block"
+    ]);
+  });
+
+  it("admin (not privileged): cannot override", () => {
+    expect(codes(applyPrivilegedOverrides(all, "admin", true))).toEqual([
+      "DENIED_DOMAIN:block",
+      "DENIED_BUCKET:block",
+      "TENANT_MISMATCH:block"
+    ]);
+  });
+
+  it("superadmin WITHOUT explicit opt-in: still fully blocked (no silent bypass)", () => {
+    expect(codes(applyPrivilegedOverrides(all, "superadmin", false))).toEqual([
+      "DENIED_DOMAIN:block",
+      "DENIED_BUCKET:block",
+      "TENANT_MISMATCH:block"
+    ]);
+  });
+
+  it("superadmin WITH opt-in: downgrades only overridable categories, audited", () => {
+    expect(codes(applyPrivilegedOverrides(all, "superadmin", true))).toEqual([
+      "DENIED_DOMAIN:warn:overridden",
+      "DENIED_BUCKET:block", // hard category never bypassable
+      "TENANT_MISMATCH:block" // tenant boundary never bypassable
+    ]);
+  });
+
+  it("owner WITH opt-in behaves like superadmin", () => {
+    const out = applyPrivilegedOverrides([overridableBlock], "owner", true);
+    expect(out[0].severity).toBe("warn");
+    expect(out[0].overridden).toBe(true);
+  });
+
+  it("does not touch pre-existing warnings or non-blocking violations", () => {
+    const warn: PolicyViolation = { code: "DENIED_DOMAIN", message: "x", severity: "warn" };
+    expect(applyPrivilegedOverrides([warn], "superadmin", true)).toEqual([warn]);
+  });
+});
