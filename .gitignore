
# ===========================
# Migra Ecosystem Platform Repo (Allowlist)
# Track ONLY:
#   - .github/**
#   - .migra/**
#   - infra/nginx/**
#   - migra-infra/wordpress/migrastacks-plugins/**
# ===========================

# Ignore everything by default
*

# Always keep gitignore
!.gitignore

# Allow .github (agents + workflows)
!.github/
!.github/**

# Allow MigraAgent artifacts
!.migra/
!.migra/**

# Allow ONLY nginx infra tree
!infra/
!infra/nginx/
!infra/nginx/**

# Allow MigraStacks enterprise WordPress plugins
!migra-infra/
!migra-infra/wordpress/
!migra-infra/wordpress/migrastacks-plugins/
!migra-infra/wordpress/migrastacks-plugins/**

# --- MigraPilot apps (allowlist) ---
!/apps/
!/apps/migrapilot-console/
!/apps/migrapilot-console/**
!/apps/migrapilot-runner-local/
!/apps/migrapilot-runner-local/**
!/apps/migrapilot-runner-server/
!/apps/migrapilot-runner-server/**
!/apps/migrapilot-desktop/
!/apps/migrapilot-desktop/**
!/apps/migrapilot-vscode-extension/
!/apps/migrapilot-vscode-extension/**
!/apps/**/package.json
!/apps/**/package-lock.json
!/apps/**/pnpm-lock.yaml
!/apps/**/yarn.lock
!/apps/**/tsconfig.json
!/apps/**/README.md

# --- MigraTeck web (allowlist) ---
!/MigraTeck/
!/MigraTeck/**

# Runtime state (never commit)
/apps/migrapilot-console/.data/
/apps/migrapilot-runner-local/.migrapilot/
/apps/migrapilot-runner-server/.migrapilot/

# ---- Never commit secrets/keys ----
*.key
*.pem
*.p12
*.pfx
*.jks
.env
.env.*
secrets/
private/
**/id_rsa
**/id_ed25519

# ---- Common junk ----
.DS_Store
Thumbs.db
.vscode/
.vscode-server/
.idea/
*.swp

# ---- Big artifacts ----
*.zip
*.tar
*.tar.gz
*.tgz
*.log
dump.rdb
test-results/
coverage/
node_modules/
dist/
build/
.next/
.cache/
tmp/
logs/
backups/
_tools/
_security_scan_outputs/
