  entityId   String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime      @default(now())
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  org        Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Enterprise Identity — Phase A
// ═══════════════════════════════════════════════════════════════════════

enum SecurityEventSeverity {
  INFO
  WARNING
  CRITICAL
}

model SecurityEvent {
  id         String                @id @default(cuid())
  userId     String?
  orgId      String?
  eventType  String
  severity   SecurityEventSeverity @default(INFO)
  ip         String?
  userAgent  String?
  country    String?
  metadata   Json?
  createdAt  DateTime              @default(now())
  user       User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  org        Organization?         @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@index([eventType, createdAt])
  @@index([severity, createdAt])
}

model UserPasskey {
  id              String    @id @default(cuid())
  userId          String
  credentialId    String    @unique
  publicKey       Bytes
  counter         BigInt    @default(0)
  deviceType      String?
  backedUp        Boolean   @default(false)
  transports      String[]
  friendlyName    String?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OrgPolicy {
  id                  String        @id @default(cuid())
  orgId               String
  requireMfa          Boolean       @default(false)
  allowedMfaMethods   String[]
  allowedEmailDomains String[]
  maxSessionDurationH Int?
  requirePasskeyForAdmin Boolean   @default(false)
  ipAllowlist         String[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  org                 Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId])
}

model Permission {
  id         String       @id @default(cuid())
  orgId      String
  userId     String
  action     String
  resource   String?
  resourceId String?
  granted    Boolean      @default(true)
  grantedBy  String?
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, action, resource, resourceId])
  @@index([userId, orgId])
  @@index([orgId, action])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model SmsOtpChallenge {
  id           String    @id @default(cuid())
  userId       String
  phone        String
  purpose      String    @default("login")
  codeHash     String
  attemptCount Int       @default(0)
  expiresAt    DateTime
  usedAt       DateTime?
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
  @@index([phone, purpose, createdAt])
  @@index([expiresAt, usedAt])
}

model RateLimitEvent {
  id        String   @id @default(cuid())
  key       String
  action    String
  createdAt DateTime @default(now())

  @@index([key, action, createdAt])
}

model LaunchTokenNonce {
  id        String     @id @default(cuid())
  nonceHash String     @unique
  userId    String
  orgId     String
  product   ProductKey
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([expiresAt, usedAt])
  @@index([userId, orgId, product])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expires])
}

model RefreshSession {
  id         String       @id @default(cuid())
  userId     String
  orgId      String
  tokenHash  String       @unique
  familyId   String
  parentId   String?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime     @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
  @@index([expiresAt])
  @@index([familyId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PilotRun {
  id                     String                         @id @default(cuid())
  source                 String
  actorUserId            String?
  delegatedByPrincipalId String?
  orgId                  String?
  environment            String                         @default("dev")
  intent                 String
  commandName            String?
  riskTier               Int                            @default(1)
  status                 PilotRunStatus                 @default(REQUESTED)
  verificationState      PilotVerificationState         @default(PENDING)
  rollbackState          PilotRollbackState             @default(NOT_REQUIRED)
  correlationId          String?
  summary                String?
  startedAt              DateTime                       @default(now())
  finishedAt             DateTime?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  actorUser              User?                          @relation("PilotRunActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  org                    Organization?                  @relation(fields: [orgId], references: [id], onDelete: SetNull)
  steps                  PilotRunStep[]
  events                 PilotEvent[]
  policyDecisions        PilotPolicyDecision[]
  approvals              PilotApproval[]
  artifacts              PilotArtifact[]
  executionLocks         PilotExecutionLock[]
  incidentLinks          PilotIncidentLink[]
  commandSnapshots       CommandDefinitionSnapshot[]
  capabilitySnapshots    CapabilityDefinitionSnapshot[]

  @@index([status, startedAt])
  @@index([orgId, startedAt])
  @@index([actorUserId, startedAt])
  @@index([commandName, startedAt])
}

model PilotRunStep {
  id                   String             @id @default(cuid())
  pilotRunId           String
  sequence             Int
  stepType             String
  title                String
  description          String?
  status               PilotRunStepStatus @default(PENDING)
  targetType           String?
  targetId             String?
  retryCount           Int                @default(0)
  rollbackStep         Boolean            @default(false)
  verificationRequired Boolean            @default(true)
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  pilotRun             PilotRun           @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)
  events               PilotEvent[]
  artifacts            PilotArtifact[]

  @@unique([pilotRunId, sequence])
  @@index([status, startedAt])
}

model PilotEvent {
  id             String        @id @default(cuid())
  pilotRunId     String
  pilotRunStepId String?
  eventType      String
  message        String
  severity       String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  pilotRun       PilotRun      @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)
  pilotRunStep   PilotRunStep? @relation(fields: [pilotRunStepId], references: [id], onDelete: SetNull)

  @@index([pilotRunId, createdAt])
  @@index([pilotRunStepId, createdAt])
}

model PilotPolicyDecision {
  id               String                    @id @default(cuid())
  pilotRunId       String
  policyName       String
  decision         PilotPolicyDecisionResult
  reason           String?
  riskTier         Int                       @default(1)
  requiresApproval Boolean                   @default(false)
  blocked          Boolean                   @default(false)
  metadata         Json?
  createdAt        DateTime                  @default(now())
  pilotRun         PilotRun                  @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)

  @@index([pilotRunId, createdAt])
  @@index([decision, createdAt])
}

model PilotApproval {
  id                      String              @id @default(cuid())
  pilotRunId              String
  approvalType            String
  status                  PilotApprovalStatus @default(PENDING)
  requestedByUserId       String?
  approverUserId          String?
  reason                  String?
  riskSummary             String?
  blastRadiusSummary      String?
  rollbackPlanSummary     String?
  verificationPlanSummary String?
  requestedAt             DateTime            @default(now())
  decidedAt               DateTime?
  pilotRun                PilotRun            @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)
  requestedByUser         User?               @relation("PilotApprovalRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approverUser            User?               @relation("PilotApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)

  @@index([status, requestedAt])
  @@index([pilotRunId, requestedAt])
}

model PilotArtifact {
  id             String                      @id @default(cuid())
  pilotRunId     String
  pilotRunStepId String?
  artifactType   String
  storageUri     String
  contentType    String?
  checksum       String?
  redactionState PilotArtifactRedactionState @default(SANITIZED)
  createdAt      DateTime                    @default(now())
  pilotRun       PilotRun                    @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)
  pilotRunStep   PilotRunStep?               @relation(fields: [pilotRunStepId], references: [id], onDelete: SetNull)

  @@index([pilotRunId, createdAt])
  @@index([artifactType, createdAt])
}

model PilotExecutionLock {
  id         String    @id @default(cuid())
  lockKey    String    @unique
  lockScope  String
  orgId      String?
  targetType String?
  targetId   String?
  pilotRunId String
  acquiredAt DateTime  @default(now())
  expiresAt  DateTime
  releasedAt DateTime?
  pilotRun   PilotRun  @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)

  @@index([orgId, acquiredAt])
  @@index([targetType, targetId])
}

model PilotIncidentLink {
  id          String   @id @default(cuid())
  pilotRunId  String
  incidentRef String
  linkType    String
  createdAt   DateTime @default(now())
  pilotRun    PilotRun @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)

  @@index([pilotRunId, createdAt])
  @@index([incidentRef, createdAt])
}

model ResourceNode {
  id              String                  @id @default(cuid())
  nodeType        ResourceNodeType
  externalId      String?
  displayName     String
  orgId           String?
  product         ProductKey?
  environment     String?
  status          String                  @default("unknown")
  metadata        Json?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  org             Organization?           @relation(fields: [orgId], references: [id], onDelete: SetNull)
  outgoingEdges   ResourceEdge[]          @relation("ResourceEdgeFrom")
  incomingEdges   ResourceEdge[]          @relation("ResourceEdgeTo")
  healthSnapshots ServiceHealthSnapshot[]

  @@index([nodeType, createdAt])
  @@index([orgId, nodeType])
  @@index([product, nodeType])
}

model ResourceEdge {
  id               String                   @id @default(cuid())
  fromNodeId       String
  toNodeId         String
  relationshipType ResourceRelationshipType
  metadata         Json?
  createdAt        DateTime                 @default(now())
  fromNode         ResourceNode             @relation("ResourceEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode           ResourceNode             @relation("ResourceEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([fromNodeId, relationshipType])
  @@index([toNodeId, relationshipType])
}

model ServiceHealthSnapshot {
  id             String             @id @default(cuid())
  resourceNodeId String
  healthState    ServiceHealthState @default(UNKNOWN)
  signalSource   String
  latencyMs      Int?
  errorRate      Float?
  metadata       Json?
  measuredAt     DateTime           @default(now())
  resourceNode   ResourceNode       @relation(fields: [resourceNodeId], references: [id], onDelete: Cascade)

  @@index([resourceNodeId, measuredAt])
  @@index([healthState, measuredAt])
}

model Runbook {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  status       String           @default("draft")
  ownerProduct ProductKey?
  serviceScope String?
  riskTier     Int              @default(1)
  orgId        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  org          Organization?    @relation(fields: [orgId], references: [id], onDelete: SetNull)
  versions     RunbookVersion[]

  @@index([status, updatedAt])
  @@index([ownerProduct, updatedAt])
}

model RunbookVersion {
  id                     String    @id @default(cuid())
  runbookId              String
  version                String
  definition             Json
  verificationDefinition Json?
  rollbackDefinition     Json?
  publishedAt            DateTime  @default(now())
  supersededAt           DateTime?
  runbook                Runbook   @relation(fields: [runbookId], references: [id], onDelete: Cascade)

  @@unique([runbookId, version])
  @@index([publishedAt])
}

model CommandDefinitionSnapshot {
  id              String   @id @default(cuid())
  pilotRunId      String
  commandName     String
  registryVersion String?
  definition      Json
  capturedAt      DateTime @default(now())
  pilotRun        PilotRun @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)

  @@index([pilotRunId, capturedAt])
  @@index([commandName, capturedAt])
}

model CapabilityDefinitionSnapshot {
  id             String   @id @default(cuid())
  pilotRunId     String
  capabilityName String
  definition     Json
  capturedAt     DateTime @default(now())
  pilotRun       PilotRun @relation(fields: [pilotRunId], references: [id], onDelete: Cascade)

  @@index([pilotRunId, capturedAt])
  @@index([capabilityName, capturedAt])
}

// ── MigraDrive Provisioning ─────────────────────────────────

enum DriveTenantStatus {
  PENDING
  ACTIVE
  RESTRICTED
  DISABLED
}

enum DriveTenantActorType {
  SYSTEM
  ADMIN
  USER
}

enum DriveFileStatus {
  PENDING_UPLOAD
  ACTIVE
  DELETED
}

model DriveTenant {
  id                String            @id @default(cuid())
  orgId             String            @unique
  orgSlug           String            @unique
  status            DriveTenantStatus @default(PENDING)
  planCode          String
  storageQuotaGb    Int
  storageUsedBytes  BigInt            @default(0)
  subscriptionId    String?
  entitlementId     String?
  externalRef       String?
  provisioningJobId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  activatedAt       DateTime?
  restrictedAt      DateTime?
  disabledAt        DateTime?
  disableReason     String?
  restrictionReason String?

  files  DriveFile[]
  events DriveTenantEvent[]
  org    Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([subscriptionId])
  @@index([entitlementId])
}

model DriveFile {
  id             String          @id @default(cuid())
  tenantId       String
  orgId          String
  objectKey      String          @unique
  fileName       String
  parentPath     String?
  mimeType       String
  sizeBytes      BigInt
  checksumSha256 String?
  status         DriveFileStatus @default(PENDING_UPLOAD)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  uploadedAt     DateTime?
  deletedAt      DateTime?

  tenant DriveTenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([orgId, parentPath, fileName])
}

model DriveTenantEvent {
  id               String               @id @default(cuid())
  tenantId         String
  orgId            String
  action           String
  previousStatus   DriveTenantStatus?
  newStatus        DriveTenantStatus?
  previousPlanCode String?
  newPlanCode      String?
  previousQuotaGb  Int?
  newQuotaGb       Int?
  subscriptionId   String?
  entitlementId    String?
  idempotencyKey   String?
  traceId          String?
  actorType        DriveTenantActorType
  actorId          String?
  metadataJson     String?
  createdAt        DateTime             @default(now())

  tenant DriveTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([orgId, createdAt])
  @@index([action, createdAt])
  @@index([idempotencyKey])
}

model DriveTenantOperation {
  id             String    @id @default(cuid())
  tenantId       String?
  orgId          String
  operationType  String
  status         String
  requestJson    String?
  responseJson   String?
  errorCode      String?
  errorMessage   String?
  idempotencyKey String?
  traceId        String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([orgId, startedAt])
  @@index([tenantId, startedAt])
  @@index([operationType, startedAt])
}

// ═══════════════════════════════════════════════════════════════════════
// MigraBuilder — AI Website Builder
// ═══════════════════════════════════════════════════════════════════════

enum BuilderSiteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BuilderDeploymentStatus {
  PENDING
  BUILDING
  DEPLOYING
  LIVE
  FAILED
  ROLLED_BACK
}

model BuilderSite {
  id            String              @id @default(cuid())
  orgId         String
  name          String
  slug          String              @unique
  domain        String?
  status        BuilderSiteStatus   @default(DRAFT)
  themeJson     Json                @default("{}")
  metaJson      Json                @default("{}")
  createdById   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  org           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy     User                @relation("BuilderSiteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  pages         BuilderPage[]
  versions      BuilderSiteVersion[]
  assets        BuilderAsset[]
  formBindings  BuilderFormBinding[]
  deployments   BuilderDeployment[]

  @@index([orgId, status])
  @@index([createdById])
}

model BuilderPage {
  id        String          @id @default(cuid())
  siteId    String
  title     String
  slug      String
  sortOrder Int             @default(0)
  metaJson  Json            @default("{}")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  site      BuilderSite     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sections  BuilderSection[]

  @@unique([siteId, slug])
  @@index([siteId, sortOrder])
}

model BuilderSection {
  id          String      @id @default(cuid())
  pageId      String
  sectionType String
  propsJson   Json        @default("{}")
  sortOrder   Int         @default(0)
  isVisible   Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  page        BuilderPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, sortOrder])
}

model BuilderSiteVersion {
  id           String              @id @default(cuid())
  siteId       String
  version      Int
  snapshotJson Json
  createdById  String
  createdAt    DateTime            @default(now())
  site         BuilderSite         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  deployments  BuilderDeployment[]

  @@unique([siteId, version])
  @@index([siteId, createdAt])
}

model BuilderAsset {
  id        String      @id @default(cuid())
  siteId    String
  fileName  String
  mimeType  String
  sizeBytes Int
  storageKey String
  createdAt DateTime    @default(now())
  site      BuilderSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
}

model BuilderFormBinding {
  id          String      @id @default(cuid())
  siteId      String
  sectionId   String
  targetType  String      @default("email")
  targetValue String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  site        BuilderSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, sectionId])
}

model BuilderDeployment {
  id          String                  @id @default(cuid())
  siteId      String
  versionId   String
  status      BuilderDeploymentStatus @default(PENDING)
  deployUrl   String?
  errorMessage String?
  startedAt   DateTime                @default(now())
  completedAt DateTime?
  site        BuilderSite             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  version     BuilderSiteVersion      @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([siteId, startedAt])
  @@index([status])
}

// ─── Phase B: API Key Management ───────────────────────────────────────

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model ApiKey {
  id           String       @id @default(cuid())
  orgId        String
  name         String
  prefixHint   String       // first 8 chars for identification
  keyHash      String       @unique
  status       ApiKeyStatus @default(ACTIVE)
  scopes       String[]     @default([])
  expiresAt    DateTime?
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ApiKeyCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([keyHash])
}

// ─── Phase B: Usage Metering ───────────────────────────────────────────

enum UsageMetric {
  API_CALLS
  STORAGE_BYTES
  BANDWIDTH_BYTES
  SEATS
  EMAILS_SENT
  SMS_SENT
  BUILDS
  DEPLOYMENTS
  VPS_HOURS
  CUSTOM
}

model UsageEvent {
  id        String      @id @default(cuid())
  orgId     String
  product   ProductKey
  metric    UsageMetric
  quantity  BigInt      @default(1)
  metadata  Json?
  timestamp DateTime    @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, product, metric, timestamp])
  @@index([orgId, timestamp])
}

model UsageQuota {
  id          String      @id @default(cuid())
  orgId       String
  product     ProductKey
  metric      UsageMetric
  limitValue  BigInt
  periodStart DateTime
  periodEnd   DateTime
  currentUsed BigInt      @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, product, metric, periodStart])
  @@index([orgId, periodEnd])
}

// ─── Phase B: Outbound Webhook Engine ──────────────────────────────────

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  EXPIRED
}

model OrgWebhookEndpoint {
  id          String        @id @default(cuid())
  orgId       String
  url         String
  secret      String        // signing secret for HMAC
  events      String[]      @default([]) // event types subscribed
  status      WebhookStatus @default(ACTIVE)
  description String?
  failCount   Int           @default(0)
  lastDeliveryAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([orgId, status])
}

model WebhookDelivery {
  id          String                @id @default(cuid())
  endpointId  String
  eventType   String
  payload     Json
  status      WebhookDeliveryStatus @default(PENDING)
  attempts    Int                   @default(0)
  maxAttempts Int                   @default(5)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?
  httpStatus    Int?
  responseBody  String?
  duration      Int?                // ms
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  endpoint    OrgWebhookEndpoint    @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([status, nextRetryAt])
  @@index([createdAt])
}

// ─── Phase D: Operations Layer ──────────────────────────────────────────

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WEBHOOK
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  SILENCED
}

enum AlertRuleStatus {
  ENABLED
  DISABLED
  SNOOZED
}

enum ScheduledTaskStatus {
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model Notification {
  id          String             @id @default(cuid())
  userId      String
  orgId       String?
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(UNREAD)
  title       String
  body        String
  actionUrl   String?
  category    String              // e.g. "billing", "provisioning", "security", "system"
  metadata    Json?
  readAt      DateTime?
  archivedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  org         Organization?       @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([userId, category])
  @@index([orgId])
}

model NotificationPreference {
  id          String             @id @default(cuid())
  userId      String
  category    String             // e.g. "billing", "provisioning", "security"
  channel     NotificationChannel
  enabled     Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, channel])
}

model PlatformEvent {
  id           String    @id @default(cuid())
  eventType    String    // e.g. "org.created", "provisioning.completed", "billing.overdue"
  source       String    // e.g. "provisioning-engine", "billing", "auth"
  orgId        String?
  actorId      String?
  entityType   String?   // e.g. "Organization", "User", "ProvisioningJob"
  entityId     String?
  payload      Json?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([eventType, createdAt])
  @@index([orgId, eventType])
  @@index([processedAt])
}

model AlertRule {
  id             String          @id @default(cuid())
  name           String
  description    String?
  status         AlertRuleStatus @default(ENABLED)
  eventType      String          // event type pattern to match (supports * wildcard)
  condition      Json            // e.g. { "field": "payload.errorRate", "op": "gt", "value": 0.05 }
  severity       AlertSeverity   @default(WARNING)
  cooldownMinutes Int            @default(60)
  notifyChannels  Json           // ["IN_APP", "EMAIL"]
  notifyRoleMin   String?        // minimum OrgRole to notify (e.g. "ADMIN")
  lastFiredAt     DateTime?
  snoozedUntil    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  alerts          Alert[]

  @@index([eventType, status])
}

model Alert {
  id           String        @id @default(cuid())
  ruleId       String?
  orgId        String?
  severity     AlertSeverity @default(WARNING)
  status       AlertStatus   @default(ACTIVE)
  title        String
  message      String
  source       String        // which system raised it
  entityType   String?
  entityId     String?
  metadata     Json?
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt     DateTime?
  resolvedBy     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  rule           AlertRule?  @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  vpsIncidents   VpsIncident[]
  vpsAlertEvent  VpsAlertEvent?

  @@index([status, severity, createdAt])
  @@index([orgId, status])
  @@index([ruleId])
}

model ScheduledTask {
  id             String              @id @default(cuid())
  name           String
  description    String?
  status         ScheduledTaskStatus @default(ACTIVE)
  cronExpression String?             // standard cron (null = one-shot)
  runAt          DateTime?           // for one-shot tasks
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  handler        String              // function/action identifier, e.g. "cleanup:expired-sessions"
  payload        Json?               // arguments passed to handler
  maxRetries     Int                 @default(3)
  retryCount     Int                 @default(0)
  lastError      String?
  lockedBy       String?             // instance ID for distributed locking
  lockedAt       DateTime?
  timeoutSeconds Int                 @default(300)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, nextRunAt])
  @@index([handler])
}

model DataExport {
  id          String    @id @default(cuid())
  orgId       String
  userId      String
  exportType  String    // e.g. "users", "audit", "usage", "billing", "all"
  format      String    @default("csv") // "csv" | "json" | "xlsx"
  status      String    @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  filters     Json?     // query filters applied
  fileKey     String?   // S3/storage key for completed export
  fileName    String?
  fileSize    Int?
  rowCount    Int?
  error       String?
  expiresAt   DateTime? // auto-delete after this date
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([userId])
  @@index([expiresAt])
}

// ─── Phase B: Billing Plan Catalog ─────────────────────────────────────

model BillingPlan {
  id              String       @id @default(cuid())
  product         ProductKey
  name            String
  slug            String       @unique
  stripePriceId   String?      @unique
  intervalMonths  Int          @default(1)   // 1=monthly, 12=annual
  priceAmountCents Int
  currency        String       @default("usd")
  features        Json?        // feature matrix { key: boolean/limit }
  trialDays       Int          @default(0)
  isPublic        Boolean      @default(true)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([product, isPublic])
}

// ─── Phase E: Ecosystem Integration ────────────────────────────────────

enum SuggestionStatus {
  ACTIVE
  DISMISSED
  ACCEPTED
  EXPIRED
}

enum SuggestionTrigger {
  DOMAIN_VERIFIED
  SITE_DEPLOYED
  SITE_PUBLISHED
  EMAIL_ACTIVE
  STORAGE_LOW
  BILLING_OVERDUE
  NO_BACKUP
  NO_VOICE
  NO_MARKETING
  PRODUCT_TRIAL_ENDING
  USAGE_MILESTONE
  MANUAL
}

enum JourneyStage {
  ONBOARDING
  ACTIVATED
  ENGAGED
  POWER_USER
  AT_RISK
  CHURNED
}

enum PartnerTier {
  REFERRAL
  AFFILIATE
  RESELLER
  AGENCY
}

enum PartnerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

model SuggestionRule {
  id              String            @id @default(cuid())
  name            String
  description     String?
  trigger         SuggestionTrigger
  sourceProduct   ProductKey?       // product that triggers suggestion
  targetProduct   ProductKey        // product being suggested
  priority        Int               @default(50) // 0=highest, 100=lowest
  title           String            // display title
  body            String            // display description
  actionLabel     String            @default("Set Up") // CTA text
  actionUrl       String?           // deep link to product setup
  conditions      Json?             // extra evaluation conditions
  isActive        Boolean           @default(true)
  maxPerOrg       Int               @default(1) // how many times per org
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  suggestions     Suggestion[]

  @@index([trigger, isActive])
  @@index([targetProduct])
}

model Suggestion {
  id            String            @id @default(cuid())
  orgId         String
  userId        String?           // null = org-wide
  ruleId        String
  status        SuggestionStatus  @default(ACTIVE)
  triggerEvent  String?           // event type that triggered this
  triggerData   Json?             // context from trigger
  dismissedAt   DateTime?
  acceptedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  org           Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  rule          SuggestionRule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([userId, status])
  @@index([ruleId])
  @@index([expiresAt])
}

model CustomerJourney {
  id                String        @id @default(cuid())
  orgId             String        @unique
  stage             JourneyStage  @default(ONBOARDING)
  score             Int           @default(0) // 0-100 health score
  productsActive    Int           @default(0)
  firstProductAt    DateTime?
  lastActivityAt    DateTime?
  trialEndsAt       DateTime?
  churnRiskScore    Int           @default(0) // 0-100
  milestones        Json?         // achieved milestones { key: timestamp }
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  org               Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model ReferralCode {
  id              String        @id @default(cuid())
  code            String        @unique
  partnerId       String        // org that owns the referral code
  description     String?
  commissionPct   Int           @default(0)  // 0-100
  maxUses         Int?          // null = unlimited
  usedCount       Int           @default(0)
  isActive        Boolean       @default(true)
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  partner         Organization  @relation("PartnerReferralCodes", fields: [partnerId], references: [id], onDelete: Cascade)
  conversions     ReferralConversion[]

  @@index([code])
  @@index([partnerId])
}

model ReferralConversion {
  id              String        @id @default(cuid())
  referralCodeId  String
  convertedOrgId  String
  convertedUserId String?
  product         ProductKey?
  revenueAmountCents Int?
  commissionAmountCents Int?
  settledAt       DateTime?
  createdAt       DateTime      @default(now())
  referralCode    ReferralCode  @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  convertedOrg    Organization  @relation("ReferralConversions", fields: [convertedOrgId], references: [id], onDelete: Cascade)

  @@index([referralCodeId])
  @@index([convertedOrgId])
}

model PartnerBinding {
  id            String        @id @default(cuid())
  orgId         String
  tier          PartnerTier   @default(REFERRAL)
  status        PartnerStatus @default(PENDING)
  companyName   String?
  contactEmail  String?
  commissionPct Int           @default(10) // default commission
  metadata      Json?
  approvedAt    DateTime?
  suspendedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId])
  @@index([status, tier])
}

model BundlePlan {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  products        ProductKey[] // products included
  stripePriceId   String?      @unique
  priceAmountCents Int
  savingsPercent  Int          @default(0)
  currency        String       @default("usd")
  intervalMonths  Int          @default(1)
  features        Json?
  trialDays       Int          @default(0)
  isPublic        Boolean      @default(true)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([isPublic])
}

// ═══════════════════════════════════════════════════════════════════════════
// Phase F: Enterprise / Compliance Posture
// ═══════════════════════════════════════════════════════════════════════════

// ─── Secret Management ────────────────────────────────────────────────────

enum SecretScope {
  PLATFORM
  ORGANIZATION
  SERVICE
}

model SecretEntry {
  id               String      @id @default(cuid())
  orgId            String?
  scope            SecretScope @default(PLATFORM)
  name             String      // logical name e.g. "STRIPE_SECRET_KEY"
  encryptedValue   String      // AES-256-GCM ciphertext (base64)
  iv               String      // initialization vector (base64)
  authTag          String      // GCM auth tag (base64)
  keyVersion       Int         @default(1) // envelope key version
  rotateAfterDays  Int?        // auto-rotation cadence
  lastRotatedAt    DateTime?
  expiresAt        DateTime?
  createdById      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  org              Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy        User?       @relation("SecretCreator", fields: [createdById], references: [id], onDelete: SetNull)
  rotationSchedules KeyRotationSchedule[]

  @@unique([orgId, scope, name])
  @@index([scope, expiresAt])
}

model KeyRotationSchedule {
  id             String    @id @default(cuid())
  secretId       String
  cronExpression String    @default("0 0 1 * *") // monthly
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  isActive       Boolean   @default(true)
  failCount      Int       @default(0)
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  secret         SecretEntry @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@index([isActive, nextRunAt])
}

// ─── Encrypted Object Storage ─────────────────────────────────────────────

model EncryptedBlob {
  id             String   @id @default(cuid())
  orgId          String?
  bucketName     String   // logical bucket (e.g. "exports", "backups")
  objectKey      String   // storage path/key
  mimeType       String?
  sizeBytes      BigInt   @default(0)
  encryptionAlgo String   @default("AES-256-GCM")
  keyVersion     Int      @default(1)
  checksumSha256 String?  // integrity check
  metadata       Json?
  expiresAt      DateTime?
  createdById    String?
  createdAt      DateTime @default(now())
  org            Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy      User?    @relation("BlobCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([bucketName, objectKey])
  @@index([orgId, bucketName])
  @@index([expiresAt])
}

// ─── Retention Policies ───────────────────────────────────────────────────

enum RetentionAction {
  DELETE
  ARCHIVE
  ANONYMIZE
}

model RetentionPolicy {
  id             String          @id @default(cuid())
  entityType     String          // e.g. "AuditLog", "UsageEvent", "DataExport"
  retentionDays  Int             // how long to keep
  action         RetentionAction @default(DELETE)
  isActive       Boolean         @default(true)
  scope          SecretScope     @default(PLATFORM) // PLATFORM or ORGANIZATION
  orgId          String?
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  org            Organization?   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  executions     RetentionExecution[]

  @@unique([entityType, scope, orgId])
  @@index([isActive])
}

model RetentionExecution {
  id            String          @id @default(cuid())
  policyId      String
  startedAt     DateTime        @default(now())
  completedAt   DateTime?
  recordsAffected Int           @default(0)
  error         String?
  policy        RetentionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId, startedAt])
}

// ─── Data Deletion (GDPR Erasure) ─────────────────────────────────────────

enum DeletionStatus {
  REQUESTED
  APPROVED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

model DataDeletionRequest {
  id            String         @id @default(cuid())
  orgId         String
  requestedById String
  subjectEmail  String         // data subject
  subjectUserId String?
  scope         String         @default("full") // "full" | "partial"
  categories    String[]       // e.g. ["audit", "usage", "billing", "personal"]
  status        DeletionStatus @default(REQUESTED)
  reason        String?
  approvedById  String?
  approvedAt    DateTime?
  executedAt    DateTime?
  completedAt   DateTime?
  certHash      String?        // SHA-256 of deletion certificate
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requestedBy   User           @relation("DeletionRequester", fields: [requestedById], references: [id])
  approvedBy    User?          @relation("DeletionApprover", fields: [approvedById], references: [id])

  @@index([orgId, status])
  @@index([subjectEmail])
}

// ─── Access Review ────────────────────────────────────────────────────────

enum AccessReviewStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AccessReviewDecision {
  KEEP
  REVOKE
  DOWNGRADE
  PENDING
}

model AccessReview {
  id           String             @id @default(cuid())
  orgId        String
  title        String
  description  String?
  initiatedById String
  status       AccessReviewStatus @default(OPEN)
  dueDate      DateTime
  completedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  org          Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  initiatedBy  User               @relation("AccessReviewInitiator", fields: [initiatedById], references: [id])
  entries      AccessReviewEntry[]

  @@index([orgId, status])
}

model AccessReviewEntry {
  id          String               @id @default(cuid())
  reviewId    String
  userId      String               // user whose access is reviewed
  membershipId String?
  currentRole String
  decision    AccessReviewDecision @default(PENDING)
  decidedById String?
  decidedAt   DateTime?
  notes       String?
  createdAt   DateTime             @default(now())
  review      AccessReview         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user        User                 @relation("AccessReviewSubject", fields: [userId], references: [id])
  decidedBy   User?                @relation("AccessReviewDecider", fields: [decidedById], references: [id])

  @@unique([reviewId, userId])
  @@index([reviewId, decision])
}

// ─── Immutable Audit Trail Rules ──────────────────────────────────────────

model AuditRetentionRule {
  id                String   @id @default(cuid())
  name              String
  description       String?
  entityType        String   @default("AuditLog")
  minRetentionDays  Int      @default(365) // immutable minimum
  preventDeletion   Boolean  @default(true)
  preventModification Boolean @default(true)
  requireApproval   Boolean  @default(false) // require dual-approval for changes
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([entityType, name])
}

// ─── Environment Separation ───────────────────────────────────────────────

enum EnvironmentTier {
  PRODUCTION
  STAGING
  DEVELOPMENT
  TESTING
}

model EnvironmentConfig {
  id           String          @id @default(cuid())
  tier         EnvironmentTier @default(PRODUCTION)
  name         String          // e.g. "production-us-east"
  description  String?
  configJson   Json            // non-sensitive environment config
  allowedOrgIds String[]       // orgs allowed in this env (empty = all)
  isDefault    Boolean         @default(false)
  isActive     Boolean         @default(true)
  isolationLevel String        @default("logical") // "logical" | "physical"
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([tier, name])
  @@index([isActive, tier])
}

// ─── Backup / Restore Validation ──────────────────────────────────────────

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  VERIFIED
  EXPIRED
}

model BackupRecord {
  id               String       @id @default(cuid())
  orgId            String?
  backupType       String       // "database" | "files" | "config" | "full"
  status           BackupStatus @default(PENDING)
  storagePath      String?
  sizeBytes        BigInt?
  checksumSha256   String?
  encryptionKeyVer Int          @default(1)
  retentionDays    Int          @default(30)
  expiresAt        DateTime?
  initiatedById    String?
  startedAt        DateTime?
  completedAt      DateTime?
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime     @default(now())
  org              Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  initiatedBy      User?        @relation("BackupInitiator", fields: [initiatedById], references: [id], onDelete: SetNull)
  validations      BackupValidation[]

  @@index([orgId, backupType])
  @@index([status, expiresAt])
}

model BackupValidation {
  id            String       @id @default(cuid())
  backupId      String
  validationType String     // "integrity" | "restore_test" | "checksum"
  passed        Boolean
  details       Json?
  validatedById String?
  validatedAt   DateTime     @default(now())
  backup        BackupRecord @relation(fields: [backupId], references: [id], onDelete: Cascade)
  validatedBy   User?        @relation("BackupValidator", fields: [validatedById], references: [id], onDelete: SetNull)

  @@index([backupId])
}

// ─── Compliance Runbooks & Incidents ──────────────────────────────────────

enum IncidentSeverity {
  SEV1
  SEV2
  SEV3
  SEV4
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  MITIGATED
  RESOLVED
  POST_MORTEM
  CLOSED
}

model ComplianceRunbook {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  category     String   // "security" | "data" | "infrastructure" | "incident"
  content      String   // markdown content
  version      Int      @default(1)
  isPublished  Boolean  @default(false)
  lastReviewAt DateTime?
  nextReviewAt DateTime?
  ownerId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  owner        User?    @relation("RunbookOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  incidents    IncidentRecord[]

  @@index([category, isPublished])
}

model IncidentRecord {
  id             String           @id @default(cuid())
  orgId          String?
  title          String
  severity       IncidentSeverity
  status         IncidentStatus   @default(OPEN)
  runbookId      String?
  description    String?
  impact         String?
  rootCause      String?
  timeline       Json?            // array of timestamped events
  mitigationSteps String?
  postMortemUrl  String?
  reportedById   String?
  assignedToId   String?
  detectedAt     DateTime         @default(now())
  mitigatedAt    DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  org            Organization?    @relation(fields: [orgId], references: [id], onDelete: SetNull)
  runbook        ComplianceRunbook? @relation(fields: [runbookId], references: [id], onDelete: SetNull)
  reportedBy     User?            @relation("IncidentReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  assignedTo     User?            @relation("IncidentAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([orgId, severity, status])
  @@index([status])
}
