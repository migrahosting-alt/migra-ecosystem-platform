generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  OWNER
  ADMIN
  BILLING
  MEMBER
  READONLY
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ProductKey {
  MIGRATECK
  MIGRAHOSTING
  MIGRAPANEL
  MIGRAVOICE
  MIGRAMAIL
  MIGRAINTAKE
  MIGRAMARKET
  MIGRAPILOT
  MIGRAINVOICE
  MIGRADRIVE
  MIGRABUILDER
}

enum EntitlementStatus {
  ACTIVE
  TRIAL
  RESTRICTED
  INTERNAL_ONLY
}

enum AccessRequestStatus {
  OPEN
  TRIAGED
  APPROVED
  DENIED
}

enum BillingProvider {
  STRIPE
}

enum BillingSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

enum BillingWebhookEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum StepUpMethod {
  NONE
  REAUTH
  TOTP
  PASSKEY
}

enum ProvisioningAction {
  ACCESS_GRANT
  ACCESS_RESTRICT
  POD_CREATE
  POD_SCALE_DOWN
  DNS_PROVISION
  VOICE_PROVISION
  VOICE_DISABLE
  MAIL_PROVISION
  MAIL_DISABLE
  INTAKE_PROVISION
  MARKET_PROVISION
  PILOT_PROVISION
  STORAGE_PROVISION
  STORAGE_READ_ONLY
  DRIVE_PROVISION
  DRIVE_DISABLE
}

enum ProvisioningTaskStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum ProvisioningJobSource {
  STRIPE
  ENTITLEMENT_EXPIRY
  MANUAL
  SYSTEM
}

enum ProvisioningJobType {
  PROVISION
  DEPROVISION
  SCALE
  RESTRICT
  UNRESTRICT
  ARTIFACT_GRANT
}

enum ProvisioningJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD
  CANCELED
}

enum PilotRunStatus {
  REQUESTED
  VALIDATING
  PLANNED
  AWAITING_APPROVAL
  EXECUTING
  VERIFYING
  COMPLETED
  FAILED
  ROLLED_BACK
  CANCELED
}

enum PilotRunStepStatus {
  PENDING
  READY
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  CANCELED
  ROLLED_BACK
}

enum PilotVerificationState {
  NOT_REQUIRED
  PENDING
  PASSED
  FAILED
}

enum PilotRollbackState {
  NOT_REQUIRED
  AVAILABLE
  STARTED
  COMPLETED
  FAILED
}

enum PilotApprovalStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
  SUPERSEDED
}

enum PilotPolicyDecisionResult {
  ALLOW
  BLOCK
  REQUIRE_APPROVAL
  ESCALATE
}

enum PilotArtifactRedactionState {
  RAW
  SANITIZED
  REDACTED
}

enum ResourceNodeType {
  TENANT
  PRODUCT
  DOMAIN
  DNS_ZONE
  ROUTE
  CERTIFICATE
  SERVICE
  INFRASTRUCTURE_NODE
  MAILBOX
  STORAGE_BUCKET
  PHONE_NUMBER
  HOSTING_SITE
  DEPLOYMENT_RELEASE
  INCIDENT
  BILLING_ACCOUNT
  OTHER
}

enum ResourceRelationshipType {
  OWNS
  BELONGS_TO
  USES
  RUNS_ON
  EXPOSES
  ROUTES_TO
  DEPENDS_ON
  PROTECTS
  BILLED_TO
  AFFECTED_BY
  MANAGED_BY
  VERIFIED_BY
}

enum ServiceHealthState {
  UNKNOWN
  HEALTHY
  DEGRADED
  UNHEALTHY
}

enum VpsStatus {
  PROVISIONING
  RUNNING
  STOPPED
  REBOOTING
  RESCUED
  REBUILDING
  SUSPENDED
  TERMINATED
  ERROR
}

enum ServerPowerState {
  ON
  OFF
  UNKNOWN
}

enum VpsBillingCycle {
  MONTHLY
  YEARLY
}

enum VpsActionType {
  POWER_ON
  POWER_OFF
  REBOOT
  HARD_REBOOT
  ENABLE_RESCUE
  DISABLE_RESCUE
  REBUILD
  OPEN_CONSOLE_SESSION
  CREATE_SNAPSHOT
  RESTORE_SNAPSHOT
  DELETE_SNAPSHOT
  UPDATE_FIREWALL
  ROLLBACK_FIREWALL
  UPDATE_BACKUP_POLICY
  MANUAL_SYNC
}

enum VpsActionStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum VpsServerMemberRole {
  OWNER
  ADMIN
  OPERATOR
  SUPPORT_VIEWER
  BILLING
  READ_ONLY
}

enum VpsProviderHealthState {
  HEALTHY
  DEGRADED
  UNREACHABLE
  UNKNOWN
}

enum VpsIncidentState {
  OPEN
  ACKNOWLEDGED
  MITIGATING
  RESOLVED
}

enum VpsAlertRuleStatus {
  ENABLED
  DISABLED
}

enum VpsAlertEventStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  SUPPRESSED
}

enum VpsSnapshotStatus {
  CREATING
  READY
  RESTORING
  FAILED
  DELETING
}

enum VpsBackupPolicyStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum VpsAuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum FirewallDirection {
  INBOUND
  OUTBOUND
}

enum FirewallAction {
  ALLOW
  DENY
}

enum FirewallProtocol {
  TCP
  UDP
  ICMP
  ANY
}

enum FirewallProfileStatus {
  DRAFT
  ACTIVE
  APPLYING
  FAILED
  DISABLED
}

enum ConsoleSessionStatus {
  REQUESTED
  READY
  ACTIVE
  EXPIRED
  FAILED
  CLOSED
}

enum SupportTier {
  STANDARD
  PRIORITY
  MANAGED
  EMERGENCY
}

model User {
  id                       String                   @id @default(cuid())
  name                     String?
  email                    String?                  @unique
  emailVerified            DateTime?
  phoneE164                String?                  @unique
  phoneVerifiedAt          DateTime?
  image                    String?
  passwordHash             String?
  defaultOrgId             String?
  failedLoginAttempts      Int                      @default(0)
  accountLockedUntil       DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  accounts                 Account[]
  sessions                 Session[]
  memberships              Membership[]
  organizationsCreated     Organization[]           @relation("OrganizationCreator")
  defaultOrg               Organization?            @relation("DefaultOrg", fields: [defaultOrgId], references: [id], onDelete: SetNull)
  auditLogs                AuditLog[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  refreshSessions          RefreshSession[]
  smsOtpChallenges         SmsOtpChallenge[]
  orgInvitationsCreated    OrgInvitation[]          @relation("OrgInvitationCreator")
  accessRequestsCreated    AccessRequest[]          @relation("AccessRequestCreator")
  provisioningTasksCreated ProvisioningTask[]       @relation("ProvisioningTaskCreator")
  mutationIntentsCreated   MutationIntent[]         @relation("MutationIntentActor")
  provisioningJobsCreated  ProvisioningJob[]        @relation("ProvisioningJobCreator")
  pilotRunsCreated         PilotRun[]               @relation("PilotRunActor")
  pilotApprovalsRequested  PilotApproval[]          @relation("PilotApprovalRequester")
  pilotApprovalsDecided    PilotApproval[]          @relation("PilotApprovalApprover")
  totpFactor               UserTotpFactor?
  passkeys                 UserPasskey[]
  securityEvents           SecurityEvent[]
  permissions              Permission[]
  builderSitesCreated      BuilderSite[]            @relation("BuilderSiteCreator")
  apiKeysCreated           ApiKey[]                 @relation("ApiKeyCreator")
  vpsServerMemberships     VpsServerMember[]
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  dataExports              DataExport[]
  suggestions              Suggestion[]
  // Phase F
  secretsCreated           SecretEntry[]         @relation("SecretCreator")
  blobsCreated             EncryptedBlob[]       @relation("BlobCreator")
  deletionRequestsMade     DataDeletionRequest[] @relation("DeletionRequester")
  deletionRequestsApproved DataDeletionRequest[] @relation("DeletionApprover")
  accessReviewsInitiated   AccessReview[]        @relation("AccessReviewInitiator")
  accessReviewSubject      AccessReviewEntry[]   @relation("AccessReviewSubject")
  accessReviewDecisions    AccessReviewEntry[]   @relation("AccessReviewDecider")
  backupsInitiated         BackupRecord[]        @relation("BackupInitiator")
  backupValidations        BackupValidation[]    @relation("BackupValidator")
  runbooksOwned            ComplianceRunbook[]   @relation("RunbookOwner")
  incidentsReported        IncidentRecord[]      @relation("IncidentReporter")
  incidentsAssigned        IncidentRecord[]      @relation("IncidentAssignee")
}


model Organization {
  id                            String                             @id @default(cuid())
  name                          String
  slug                          String                             @unique
  isMigraHostingClient          Boolean                            @default(false)
  createdById                   String?
  createdAt                     DateTime                           @default(now())
  updatedAt                     DateTime                           @updatedAt
  memberships                   Membership[]
  entitlements                  OrgEntitlement[]
  auditLogs                     AuditLog[]
  createdBy                     User?                              @relation("OrganizationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  defaultForUsers               User[]                             @relation("DefaultOrg")
  invites                       OrgInvitation[]
  accessRequests                AccessRequest[]
  revenueOnboardingContacts     RevenueOnboardingContact[]
  billingCustomers              BillingCustomer[]
  billingSubscriptions          BillingSubscription[]
  provisioningTasks             ProvisioningTask[]
  mutationIntents               MutationIntent[]
  provisioningJobs              ProvisioningJob[]
  pilotRuns                     PilotRun[]
  resourceNodes                 ResourceNode[]
  runbooks                      Runbook[]
  migraMarketAccount            MigraMarketAccount?
  migraMarketLocations          MigraMarketLocation[]
  migraMarketChecklistItems     MigraMarketChecklistItem[]
  migraMarketTasks              MigraMarketTask[]
  migraMarketReports            MigraMarketReportSnapshot[]
  migraMarketLeadForms          MigraMarketLeadCaptureForm[]
  migraMarketLeads              MigraMarketLeadRecord[]
  migraMarketCampaigns          MigraMarketMessagingCampaign[]
  migraMarketDeliveries         MigraMarketMessagingDelivery[]
  migraMarketWebhookEvents      MigraMarketMessagingWebhookEvent[]
  migraMarketSocialConnections  MigraMarketSocialConnection[]
  migraMarketCreativeBriefs     MigraMarketCreativeBrief[]
  migraMarketContentJobs        MigraMarketContentJob[]
  migraMarketContentTemplates   MigraMarketContentTemplate[]
  migraMarketCalendarSlots      MigraMarketContentCalendarSlot[]
  migraMarketContentAssets      MigraMarketContentAsset[]
  migraMarketContentCaptions    MigraMarketContentCaption[]
  migraMarketOgSnapshots        MigraMarketOgSnapshot[]
  migraMarketPublishValidations MigraMarketPublishValidation[]
  driveFiles                    DriveFile[]
  driveTenants                  DriveTenant[]
  vpsServers                    VpsServer[]
  vpsAlertRules                 VpsAlertRule[]
  vpsAlertEvents                VpsAlertEvent[]
  refreshSessions               RefreshSession[]
  securityEvents                SecurityEvent[]
  orgPolicy                     OrgPolicy?
  permissions                   Permission[]
  builderSites                  BuilderSite[]
  apiKeys                       ApiKey[]
  usageEvents                   UsageEvent[]
  usageQuotas                   UsageQuota[]
  webhookEndpoints              OrgWebhookEndpoint[]
  notifications                 Notification[]
  dataExports                   DataExport[]
  suggestions                   Suggestion[]
  customerJourney               CustomerJourney?
  partnerReferralCodes          ReferralCode[]           @relation("PartnerReferralCodes")
  referralConversions           ReferralConversion[]     @relation("ReferralConversions")
  partnerBinding                PartnerBinding?
  // Phase F
  secrets                       SecretEntry[]
  encryptedBlobs                EncryptedBlob[]
  retentionPolicies             RetentionPolicy[]
  dataDeletionRequests          DataDeletionRequest[]
  accessReviews                 AccessReview[]
  backupRecords                 BackupRecord[]
  incidents                     IncidentRecord[]
}

model Membership {
  id        String           @id @default(cuid())
  userId    String
  orgId     String
  role      OrgRole          @default(MEMBER)
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId, role])
}

model OrgEntitlement {
  id        String            @id @default(cuid())
  orgId     String
  product   ProductKey
  status    EntitlementStatus @default(RESTRICTED)
  startsAt  DateTime?
  endsAt    DateTime?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  org       Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, product])
  @@index([product, status])
}

model PlatformConfig {
  id                           String   @id
  allowPublicSignup            Boolean  @default(false)
  allowOrgCreate               Boolean  @default(false)
  waitlistMode                 Boolean  @default(false)
  maintenanceMode              Boolean  @default(false)
  freezeProvisioning           Boolean  @default(false)
  pauseProvisioningWorker      Boolean  @default(false)
  pauseEntitlementExpiryWorker Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model OrgInvitation {
  id              String       @id @default(cuid())
  orgId           String
  email           String
  role            OrgRole
  tokenHash       String       @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdByUserId String
  createdAt       DateTime     @default(now())
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdByUser   User         @relation("OrgInvitationCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@index([expiresAt])
}

model AccessRequest {
  id              String              @id @default(cuid())
  orgId           String
  product         ProductKey
  message         String?
  status          AccessRequestStatus @default(OPEN)
  createdByUserId String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  org             Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdByUser   User                @relation("AccessRequestCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([product, status])
}

model VpsServer {
  id                         String               @id @default(cuid())
  orgId                      String
  customerUserId             String?
  providerSlug               String               @default("manual")
  providerServerId           String?              @unique
  providerRegionId           String?
  providerPlanId             String?
  name                       String
  hostname                   String
  instanceId                 String
  status                     VpsStatus            @default(PROVISIONING)
  powerState                 ServerPowerState     @default(UNKNOWN)
  publicIpv4                 String
  privateIpv4                String?
  gatewayIpv4                String?
  privateNetwork             String?
  sshPort                    Int                  @default(22)
  defaultUsername            String               @default("root")
  region                     String
  datacenterLabel            String?
  imageSlug                  String
  osName                     String
  imageVersion               String?
  virtualizationType         String?
  planSlug                   String
  planName                   String?
  vcpu                       Int
  memoryMb                   Int
  diskGb                     Int
  bandwidthTb                Int
  bandwidthUsedGb            Int                  @default(0)
  reverseDns                 String?
  reverseDnsStatus           String?
  firewallEnabled            Boolean              @default(true)
  firewallProfileName        String?
  monitoringEnabled          Boolean              @default(false)
  monitoringStatus           String?
  backupsEnabled             Boolean              @default(false)
  backupRegion               String?
  snapshotCountCached        Int                  @default(0)
  nextInvoiceAt              DateTime?
  renewalAt                  DateTime?
  billingCycle               VpsBillingCycle      @default(MONTHLY)
  monthlyPriceCents          Int                  @default(0)
  billingCurrency            String               @default("USD")
  supportTier                SupportTier?
  supportTicketUrl           String?
  supportDocsUrl             String?
  rescueEnabled              Boolean              @default(false)
  providerHealthState        VpsProviderHealthState @default(UNKNOWN)
  providerLastCheckedAt      DateTime?
  providerError              String?
  driftDetectedAt            DateTime?
  driftType                  String?
  lastSyncedAt               DateTime?
  lastKnownProviderStateJson Json?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  organization               Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  snapshots                  VpsSnapshot[]
  backupPolicies             VpsBackupPolicy[]
  metrics                    VpsMetricRollup[]
  actions                    VpsActionJob[]
  audits                     VpsAuditEvent[]
  firewallProfiles           VpsFirewallProfile[]
  supportLinks               VpsSupportLink[]
  consoleSessions            VpsConsoleSession[]
  providerBindings           VpsProviderBinding[]
  members                    VpsServerMember[]
  incidents                  VpsIncident[]
  alertEvents                VpsAlertEvent[]

  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, providerHealthState])
  @@index([orgId, driftDetectedAt])
}

model VpsAlertRule {
  id                   String             @id @default(cuid())
  orgId                String
  code                 String
  name                 String
  description          String?
  status               VpsAlertRuleStatus @default(ENABLED)
  severity             AlertSeverity      @default(WARNING)
  escalationEnabled    Boolean            @default(false)
  responseSlaMinutes   Int?
  mitigationSlaMinutes Int?
  suppressionMinutes   Int                @default(60)
  metadataJson         Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  events               VpsAlertEvent[]

  @@unique([orgId, code])
  @@index([orgId, status, severity])
}

model VpsAlertEvent {
  id                String              @id @default(cuid())
  orgId             String
  serverId          String
  ruleId            String
  alertId           String?
  status            VpsAlertEventStatus @default(ACTIVE)
  fingerprint       String
  severity          AlertSeverity       @default(WARNING)
  title             String
  message           String
  source            String
  detailJson        Json?
  acknowledgedAt    DateTime?
  acknowledgedBy    String?
  resolvedAt        DateTime?
  firstDetectedAt   DateTime            @default(now())
  lastDetectedAt    DateTime            @default(now())
  suppressedUntil   DateTime?
  lastRemediationJobId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  organization      Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  server            VpsServer           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  rule              VpsAlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  alert             Alert?              @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@unique([serverId, fingerprint])
  @@unique([alertId])
  @@index([orgId, status, severity, lastDetectedAt])
  @@index([serverId, status, lastDetectedAt])
}

model VpsServerMember {
  id        String              @id @default(cuid())
  serverId  String
  userId    String
  role      VpsServerMemberRole
  createdAt DateTime            @default(now())
  server    VpsServer           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@index([userId, role])
}

model VpsIncident {
  id                   String           @id @default(cuid())
  serverId             String
  orgId                String
  alertId              String?
  state                VpsIncidentState @default(OPEN)
  severity             AlertSeverity    @default(WARNING)
  openedAt             DateTime         @default(now())
  responseDeadlineAt   DateTime?
  mitigationDeadlineAt DateTime?
  breachedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  server               VpsServer        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  alert                Alert?           @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@unique([alertId])
  @@index([orgId, state, openedAt])
  @@index([serverId, state, openedAt])
}

model VpsActionJob {
  id                String          @id @default(cuid())
  serverId          String
  orgId             String
  action            VpsActionType
  status            VpsActionStatus @default(QUEUED)
  requestedByUserId String
  requestJson       Json?
  resultJson        Json?
  errorJson         Json?
  providerRequestId String?
  providerTaskId    String?
  correlationId     String          @default(cuid())
  retryCount        Int             @default(0)
  attemptCount      Int             @default(0)
  startedAt         DateTime?
  finishedAt        DateTime?
  nextPollAt        DateTime?
  createdAt         DateTime        @default(now())
  server            VpsServer       @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([serverId, createdAt])
  @@index([status, createdAt])
  @@index([providerTaskId])
}

model VpsSnapshot {
  id        String            @id @default(cuid())
  serverId  String
  name      String
  note      String?
  status    VpsSnapshotStatus @default(CREATING)
  sizeGb    Int?
  createdBy String?
  createdAt DateTime          @default(now())
  server    VpsServer         @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
}

model VpsBackupPolicy {
  id             String                @id @default(cuid())
  serverId       String
  status         VpsBackupPolicyStatus @default(DISABLED)
  frequency      String
  retentionCount Int
  lastSuccessAt  DateTime?
  nextRunAt      DateTime?
  encrypted      Boolean               @default(true)
  crossRegion    Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  server         VpsServer             @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, updatedAt])
}

model VpsMetricRollup {
  id             String    @id @default(cuid())
  serverId       String
  cpuPercent     Float     @default(0)
  memoryPercent  Float     @default(0)
  diskPercent    Float     @default(0)
  networkInMbps  Float     @default(0)
  networkOutMbps Float     @default(0)
  uptimeSeconds  BigInt    @default(0)
  capturedAt     DateTime  @default(now())
  server         VpsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, capturedAt])
}

model VpsAuditEvent {
  id           String           @id @default(cuid())
  orgId        String
  serverId     String
  actorUserId  String?
  eventType    String
  severity     VpsAuditSeverity @default(INFO)
  sourceIp     String?
  relatedJobId String?
  payloadJson  Json?
  createdAt    DateTime         @default(now())
  server       VpsServer        @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([serverId, createdAt])
}

model VpsFirewallProfile {
  id                    String            @id @default(cuid())
  serverId              String
  providerProfileId     String?
  name                  String
  status                FirewallProfileStatus @default(DRAFT)
  version               Int               @default(1)
  defaultInboundAction  FirewallAction    @default(DENY)
  defaultOutboundAction FirewallAction    @default(ALLOW)
  antiLockoutEnabled    Boolean           @default(true)
  rollbackWindowSec     Int               @default(120)
  protectionMode        String?
  providerVersion       String?
  lastAppliedAt         DateTime?
  lastApplyJobId        String?
  lastError             String?
  isActive              Boolean           @default(false)
  rollbackPendingUntil  DateTime?
  confirmedAt           DateTime?
  driftDetectedAt       DateTime?
  driftSummaryJson      Json?
  lastKnownGoodJson     Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  server                VpsServer         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  rules                 VpsFirewallRule[]

  @@index([serverId, updatedAt])
  @@index([serverId, isActive])
}

model VpsFirewallRule {
  id              String             @id @default(cuid())
  profileId       String
  direction       FirewallDirection
  action          FirewallAction
  protocol        FirewallProtocol   @default(TCP)
  portStart       Int?
  portEnd         Int?
  portRange       String?
  sourceCidr      String?
  destinationCidr String?
  description     String?
  priority        Int                @default(100)
  enabled         Boolean            @default(true)
  expiresAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  profile         VpsFirewallProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, priority])
  @@index([profileId, direction, priority])
}

model VpsSupportLink {
  id               String    @id @default(cuid())
  serverId         String
  externalTicketId String?
  title            String?
  category         String?
  priority         String?
  status           String    @default("OPEN")
  url              String?
  metadataJson     Json?
