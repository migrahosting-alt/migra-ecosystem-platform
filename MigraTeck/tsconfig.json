{
  "extends": "./packages/config/tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@migrateck/api-contracts": [
        "./packages/api-contracts/src/index.ts"
      ],
      "@migrateck/auth-core": [
        "./packages/auth-core/src/index.ts"
      ],
      "@migrateck/org-core": [
        "./packages/org-core/src/index.ts"
      ],
      "@migrateck/audit-core": [
        "./packages/audit-core/src/index.ts"
      ],
      "@migrateck/events": [
        "./packages/events/src/index.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "middleware.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
