// MigraAuth — Centralized Identity Platform
// Database: PostgreSQL dedicated to auth (auth_migrateck)
// Aligned to 001_init_migraauth.sql — this is the Prisma mirror.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/auth-client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────

enum UserStatus {
  PENDING  @map("pending")
  ACTIVE   @map("active")
  LOCKED   @map("locked")
  DISABLED @map("disabled")

  @@map("user_status")
}

enum CredentialType {
  PASSWORD      @map("password")
  TOTP          @map("totp")
  PASSKEY       @map("passkey")
  RECOVERY_CODE @map("recovery_code")

  @@map("credential_type")
}

enum TokenStatus {
  ACTIVE  @map("active")
  USED    @map("used")
  REVOKED @map("revoked")
  EXPIRED @map("expired")

  @@map("token_status")
}

enum MemberRole {
  OWNER         @map("owner")
  ADMIN         @map("admin")
  BILLING_ADMIN @map("billing_admin")
  MEMBER        @map("member")

  @@map("member_role")
}

enum MemberStatus {
  INVITED   @map("invited")
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")

  @@map("member_status")
}

enum SessionType {
  AUTH @map("auth")
  APP  @map("app")

  @@map("session_type")
}

enum AuditActorType {
  USER    @map("user")
  SYSTEM  @map("system")
  ADMIN   @map("admin")
  SERVICE @map("service")

  @@map("audit_actor_type")
}

// ─── Users ──────────────────────────────────────────────────────────

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.Citext
  status          UserStatus @default(PENDING)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz
  displayName     String?    @map("display_name") @db.VarChar(120)
  givenName       String?    @map("given_name") @db.VarChar(120)
  familyName      String?    @map("family_name") @db.VarChar(120)
  avatarUrl       String?    @map("avatar_url")
  locale          String     @default("en") @db.VarChar(10)
  timezone        String     @default("UTC") @db.VarChar(60)
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz
  lockedAt        DateTime?  @map("locked_at") @db.Timestamptz
  disabledAt      DateTime?  @map("disabled_at") @db.Timestamptz
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz

  credentials        UserCredential[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  authCodes          OAuthAuthorizationCode[]
  refreshTokens      OAuthRefreshToken[]
  sessions           Session[]
  mfaChallenges      MfaChallenge[]
  orgMemberships     OrganizationMember[]
  organizationsOwned Organization[]
  ownedOAuthClients  OAuthClient[] @relation("OAuthClientOwner")
  auditLogs          AuditLog[] @relation("AuditActor")
  auditTargets       AuditLog[] @relation("AuditTarget")

  @@map("users")
}

// ─── Credentials ────────────────────────────────────────────────────

model UserCredential {
  id         String         @id @default(uuid()) @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  type       CredentialType
  secretHash String?        @map("secret_hash")
  metadata   Json           @default("{}")
  priority   Int            @default(0) @db.SmallInt
  isEnabled  Boolean        @default(true) @map("is_enabled")
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credentials")
}

// ─── Email Verification ─────────────────────────────────────────────

model EmailVerification {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  tokenHash String      @map("token_hash")
  status    TokenStatus @default(ACTIVE)
  expiresAt DateTime    @map("expires_at") @db.Timestamptz
  usedAt    DateTime?   @map("used_at") @db.Timestamptz
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// ─── Password Reset ─────────────────────────────────────────────────

model PasswordReset {
  id                 String      @id @default(uuid()) @db.Uuid
  userId             String      @map("user_id") @db.Uuid
  tokenHash          String      @map("token_hash")
  status             TokenStatus @default(ACTIVE)
  expiresAt          DateTime    @map("expires_at") @db.Timestamptz
  usedAt             DateTime?   @map("used_at") @db.Timestamptz
  requestedIp        String?     @map("requested_ip") @db.Inet
  requestedUserAgent String?     @map("requested_user_agent")
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ─── OAuth Clients ──────────────────────────────────────────────────

model OAuthClient {
  id                     String   @id @default(uuid()) @db.Uuid
  clientId               String   @unique @map("client_id") @db.VarChar(100)
  clientName             String   @map("client_name") @db.VarChar(120)
  description            String?  @db.VarChar(500)
  clientSecretHash       String?  @map("client_secret_hash")
  clientType             String   @map("client_type") @db.VarChar(20)
  redirectUris           Json     @map("redirect_uris")
  postLogoutRedirectUris Json     @default("[]") @map("post_logout_redirect_uris")
  allowedScopes          Json     @default("[\"openid\"]") @map("allowed_scopes")
  requiresPkce           Boolean  @default(true) @map("requires_pkce")
  tokenAuthMethod        String   @default("none") @map("token_auth_method") @db.VarChar(40)
  isFirstParty           Boolean  @default(true) @map("is_first_party")
  isActive               Boolean  @default(true) @map("is_active")
  ownerUserId            String?  @map("owner_user_id") @db.Uuid
  ownerOrganizationId    String?  @map("owner_organization_id") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  ownerUser         User?         @relation("OAuthClientOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OAuthClientOrganization", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([ownerOrganizationId])
  @@map("oauth_clients")
}

// ─── Authorization Codes ────────────────────────────────────────────

model OAuthAuthorizationCode {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  clientId            String    @map("client_id") @db.VarChar(100)
  codeHash            String    @map("code_hash")
  codeChallenge       String    @map("code_challenge")
  codeChallengeMethod String    @map("code_challenge_method") @db.VarChar(10)
  redirectUri         String    @map("redirect_uri")
  scope               String    @default("openid")
  nonce               String?
  stateHash           String?   @map("state_hash")
  nonceHash           String?   @map("nonce_hash")
  issuedIp            String?   @map("issued_ip") @db.Inet
  issuedUserAgent     String?   @map("issued_user_agent")
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz
  usedAt              DateTime? @map("used_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("oauth_authorization_codes")
}

// ─── Refresh Tokens ─────────────────────────────────────────────────

model OAuthRefreshToken {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  clientId        String    @map("client_id") @db.VarChar(100)
  tokenHash       String    @map("token_hash")
  familyId        String    @map("family_id") @db.Uuid
  parentTokenId   String?   @map("parent_token_id") @db.Uuid
  scope           String    @default("openid")
  issuedAt        DateTime  @map("issued_at") @db.Timestamptz
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  rotatedAt       DateTime? @map("rotated_at") @db.Timestamptz
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz
  reuseDetectedAt DateTime? @map("reuse_detected_at") @db.Timestamptz
  ipAddress       String?   @map("ip_address") @db.Inet
  userAgent       String?   @map("user_agent")
  deviceId        String?   @map("device_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([tokenHash])
  @@map("oauth_refresh_tokens")
}

// ─── Sessions ───────────────────────────────────────────────────────

model Session {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  sessionType       SessionType @default(AUTH) @map("session_type")
  clientId          String?     @map("client_id") @db.VarChar(100)
  sessionSecretHash String      @map("session_secret_hash")
  deviceId          String?     @map("device_id") @db.Uuid
  deviceName        String?     @map("device_name") @db.VarChar(120)
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  expiresAt         DateTime    @map("expires_at") @db.Timestamptz
  revokedAt         DateTime?   @map("revoked_at") @db.Timestamptz
  lastSeenAt        DateTime?   @map("last_seen_at") @db.Timestamptz
  ipAddress         String?     @map("ip_address") @db.Inet
  userAgent         String?     @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionSecretHash])
  @@map("sessions")
}

// ─── Organizations ──────────────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(160)
  slug        String   @unique @db.VarChar(120)
  ownerUserId String   @map("owner_user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  owner   User                 @relation(fields: [ownerUserId], references: [id])
  members OrganizationMember[]
  oauthClients OAuthClient[]   @relation("OAuthClientOrganization")

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           MemberRole   @default(MEMBER)
  status         MemberStatus @default(INVITED)
  joinedAt       DateTime?    @map("joined_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

// ─── MFA Challenges ─────────────────────────────────────────────────

model MfaChallenge {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  method        String    @db.VarChar(20)
  challengeHash String    @map("challenge_hash")
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz
  verifiedAt    DateTime? @map("verified_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_challenges")
}

// ─── Audit Logs ─────────────────────────────────────────────────────

model AuditLog {
  id           String         @id @default(uuid()) @db.Uuid
  actorUserId  String?        @map("actor_user_id") @db.Uuid
  actorType    AuditActorType @default(USER) @map("actor_type")
  targetUserId String?        @map("target_user_id") @db.Uuid
  clientId     String?        @map("client_id") @db.VarChar(100)
  eventType    String         @map("event_type") @db.VarChar(80)
  eventData    Json           @default("{}") @map("event_data")
  ipAddress    String?        @map("ip_address") @db.Inet
  userAgent    String?        @map("user_agent")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz

  actor  User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([eventType])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Billing Enums ───────────────────────────────────────────────────

enum BillingAccountStatus {
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")
  CLOSED    @map("closed")

  @@map("billing_account_status")
}

enum SubscriptionStatus {
  ACTIVE             @map("active")
  TRIALING           @map("trialing")
  PAST_DUE           @map("past_due")
  PAUSED             @map("paused")
  CANCELED           @map("canceled")
  INCOMPLETE         @map("incomplete")
  INCOMPLETE_EXPIRED @map("incomplete_expired")
  UNPAID             @map("unpaid")

  @@map("subscription_status")
}

enum BillingComponentType {
  BASE       @map("base")
  SEAT       @map("seat")
  USAGE      @map("usage")
  ONBOARDING @map("onboarding")

  @@map("billing_component_type")
}

enum BillingInterval {
  MONTH @map("month")
  YEAR  @map("year")

  @@map("billing_interval")
}

enum InvoiceStatus {
  DRAFT         @map("draft")
  OPEN          @map("open")
  PAID          @map("paid")
  VOID          @map("void")
  UNCOLLECTIBLE @map("uncollectible")

  @@map("invoice_status")
}

enum QuoteStatus {
  DRAFT    @map("draft")
  OPEN     @map("open")
  ACCEPTED @map("accepted")
  CANCELED @map("canceled")

  @@map("quote_status")
}

enum DunningState {
  ACTIVE       @map("active")
  PAST_DUE     @map("past_due")
  GRACE_PERIOD @map("grace_period")
  RESTRICTED   @map("restricted")
  SUSPENDED    @map("suspended")
  CANCELED     @map("canceled")

  @@map("dunning_state")
}

enum WebhookEventStatus {
  PENDING   @map("pending")
  PROCESSED @map("processed")
  FAILED    @map("failed")
  SKIPPED   @map("skipped")

  @@map("webhook_event_status")
}

enum AdjustmentKind {
  CREDIT         @map("credit")
  SERVICE_CREDIT @map("service_credit")
  GOODWILL       @map("goodwill")
  REFUND         @map("refund")
  PROMO          @map("promo")

  @@map("adjustment_kind")
}

enum UsageSource {
  API    @map("api")
  WORKER @map("worker")
  SYSTEM @map("system")
  MANUAL @map("manual")

  @@map("usage_source")
}

enum EntitlementSourceType {
  SUBSCRIPTION    @map("subscription")
  TRIAL           @map("trial")
  MANUAL_OVERRIDE @map("manual_override")
  PROMOTIONAL     @map("promotional")

  @@map("entitlement_source_type")
}

// ─── Billing Models ──────────────────────────────────────────────────

model BillingAccount {
  id                 String               @id @default(uuid()) @db.Uuid
  orgId              String               @unique @map("org_id") @db.Uuid
  stripeCustomerId   String?              @unique @map("stripe_customer_id") @db.VarChar(255)
  defaultCurrency    String               @default("usd") @map("default_currency") @db.VarChar(3)
  billingEmail       String?              @map("billing_email") @db.VarChar(255)
  billingContactName String?              @map("billing_contact_name") @db.VarChar(255)
  taxCountry         String?              @map("tax_country") @db.VarChar(2)
  taxState           String?              @map("tax_state") @db.VarChar(80)
  taxId              String?              @map("tax_id") @db.VarChar(80)
  status             BillingAccountStatus @default(ACTIVE)
  dunningState       DunningState         @default(ACTIVE) @map("dunning_state")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions  BillingSubscription[]
  invoices       BillingInvoice[]
  paymentMethods BillingPaymentMethod[]
  adjustments    BillingAdjustment[]
  quotes         BillingQuote[]
  usageEvents    BillingUsageEvent[]
  entitlements   BillingEntitlementSnapshot[]

  @@map("billing_accounts")
}

model BillingSubscription {
  id                   String             @id @default(uuid()) @db.Uuid
  orgId                String             @map("org_id") @db.Uuid
  billingAccountId     String             @map("billing_account_id") @db.Uuid
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id") @db.VarChar(255)
  productFamily        String             @map("product_family") @db.VarChar(40)
  planCode             String             @map("plan_code") @db.VarChar(40)
  status               SubscriptionStatus @default(INCOMPLETE)
  billingInterval      BillingInterval    @default(MONTH) @map("billing_interval")
  currentPeriodStart   DateTime?          @map("current_period_start") @db.Timestamptz
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  trialEndsAt          DateTime?          @map("trial_ends_at") @db.Timestamptz
  pausedAt             DateTime?          @map("paused_at") @db.Timestamptz
  canceledAt           DateTime?          @map("canceled_at") @db.Timestamptz
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  billingAccount BillingAccount           @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  items          BillingSubscriptionItem[]

  @@index([orgId, productFamily])
  @@index([stripeSubscriptionId])
  @@map("billing_subscriptions")
}

model BillingSubscriptionItem {
  id                       String               @id @default(uuid()) @db.Uuid
  billingSubscriptionId    String               @map("billing_subscription_id") @db.Uuid
  stripeSubscriptionItemId String?              @unique @map("stripe_subscription_item_id") @db.VarChar(255)
  componentType            BillingComponentType @map("component_type")
  priceLookupKey           String?              @map("price_lookup_key") @db.VarChar(120)
  quantity                 Int?
  meterName                String?              @map("meter_name") @db.VarChar(80)
  createdAt                DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  subscription BillingSubscription @relation(fields: [billingSubscriptionId], references: [id], onDelete: Cascade)

  @@map("billing_subscription_items")
}

model BillingInvoice {
  id                   String        @id @default(uuid()) @db.Uuid
  orgId                String        @map("org_id") @db.Uuid
  billingAccountId     String        @map("billing_account_id") @db.Uuid
  stripeInvoiceId      String?       @unique @map("stripe_invoice_id") @db.VarChar(255)
  stripeSubscriptionId String?       @map("stripe_subscription_id") @db.VarChar(255)
  status               InvoiceStatus @default(DRAFT)
  currency             String        @default("usd") @db.VarChar(3)
  subtotal             Int           @default(0)
  tax                  Int           @default(0)
  total                Int           @default(0)
  amountPaid           Int           @default(0) @map("amount_paid")
  amountRemaining      Int           @default(0) @map("amount_remaining")
  hostedInvoiceUrl     String?       @map("hosted_invoice_url")
  invoicePdf           String?       @map("invoice_pdf")
  periodStart          DateTime?     @map("period_start") @db.Timestamptz
  periodEnd            DateTime?     @map("period_end") @db.Timestamptz
  issuedAt             DateTime?     @map("issued_at") @db.Timestamptz
  paidAt               DateTime?     @map("paid_at") @db.Timestamptz
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([stripeInvoiceId])
  @@map("billing_invoices")
}

model BillingPaymentMethod {
  id                    String   @id @default(uuid()) @db.Uuid
  orgId                 String   @map("org_id") @db.Uuid
  billingAccountId      String   @map("billing_account_id") @db.Uuid
  stripePaymentMethodId String   @unique @map("stripe_payment_method_id") @db.VarChar(255)
  type                  String   @db.VarChar(40)
  brand                 String?  @db.VarChar(40)
  last4                 String?  @db.VarChar(4)
  expMonth              Int?     @map("exp_month")
  expYear               Int?     @map("exp_year")
  isDefault             Boolean  @default(false) @map("is_default")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("billing_payment_methods")
}

model BillingUsageEvent {
  id                 String      @id @default(uuid()) @db.Uuid
  orgId              String      @map("org_id") @db.Uuid
  billingAccountId   String      @map("billing_account_id") @db.Uuid
  productFamily      String      @map("product_family") @db.VarChar(40)
  meterName          String      @map("meter_name") @db.VarChar(80)
  quantity           Int
  windowStart        DateTime    @map("window_start") @db.Timestamptz
  windowEnd          DateTime    @map("window_end") @db.Timestamptz
  idempotencyKey     String      @unique @map("idempotency_key") @db.VarChar(255)
  source             UsageSource @default(API)
  reportedToStripeAt DateTime?   @map("reported_to_stripe_at") @db.Timestamptz
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([orgId, productFamily, meterName])
  @@index([reportedToStripeAt])
  @@map("billing_usage_events")
}

model BillingEntitlementSnapshot {
  id               String                @id @default(uuid()) @db.Uuid
  orgId            String                @map("org_id") @db.Uuid
  billingAccountId String                @map("billing_account_id") @db.Uuid
  sourceType       EntitlementSourceType @map("source_type")
  sourceId         String                @map("source_id") @db.VarChar(255)
  entitlementsJson Json                  @map("entitlements_json")
  effectiveAt      DateTime              @map("effective_at") @db.Timestamptz
  expiresAt        DateTime?             @map("expires_at") @db.Timestamptz
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("billing_entitlement_snapshots")
}

model BillingQuote {
  id               String      @id @default(uuid()) @db.Uuid
  orgId            String      @map("org_id") @db.Uuid
  billingAccountId String      @map("billing_account_id") @db.Uuid
  stripeQuoteId    String?     @unique @map("stripe_quote_id") @db.VarChar(255)
  status           QuoteStatus @default(DRAFT)
  expiresAt        DateTime?   @map("expires_at") @db.Timestamptz
  acceptedAt       DateTime?   @map("accepted_at") @db.Timestamptz
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("billing_quotes")
}

model BillingWebhookEvent {
  id            String             @id @default(uuid()) @db.Uuid
  stripeEventId String             @unique @map("stripe_event_id") @db.VarChar(255)
  type          String             @db.VarChar(120)
  processedAt   DateTime?          @map("processed_at") @db.Timestamptz
  status        WebhookEventStatus @default(PENDING)
  payloadJson   Json               @map("payload_json")
  errorMessage  String?            @map("error_message")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz

  @@index([stripeEventId])
  @@index([status])
  @@map("billing_webhook_events")
}

model BillingAdjustment {
  id                 String         @id @default(uuid()) @db.Uuid
  orgId              String         @map("org_id") @db.Uuid
  billingAccountId   String         @map("billing_account_id") @db.Uuid
  kind               AdjustmentKind
  amount             Int
  currency           String         @default("usd") @db.VarChar(3)
  reason             String
  stripeCreditNoteId String?        @map("stripe_credit_note_id") @db.VarChar(255)
  createdByUserId    String         @map("created_by_user_id") @db.Uuid
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("billing_adjustments")
}
