{
  "name": "migrapilot-vscode",
  "displayName": "MigraPilot Chat",
  "description": "MigraPilot \u2014 an AI engineering chat assistant for the MigraTeck ecosystem, with live editor context.",
  "version": "0.18.0",
  "publisher": "migrateck",
  "engines": {
    "vscode": "^1.95.0"
  },
  "main": "./out/extension.js",
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "migrapilot",
          "title": "MigraPilot",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "migrapilot": [
        {
          "id": "migrapilot.chat",
          "name": "MigraPilot",
          "type": "webview"
        },
        {
          "id": "migrapilot.conversations",
          "name": "Conversations",
          "icon": "$(comment-discussion)",
          "contextualTitle": "MigraPilot Conversations"
        }
      ]
    },
    "commands": [
      {
        "command": "migrapilot.openChat",
        "title": "MigraPilot: Open Chat"
      },
      {
        "command": "migrapilot.newChat",
        "title": "MigraPilot: New Chat"
      },
      {
        "command": "migrapilot.explainCurrentFile",
        "title": "MigraPilot: Explain Current File"
      },
      {
        "command": "migrapilot.reviewSelection",
        "title": "MigraPilot: Review Selection"
      },
      {
        "command": "migrapilot.attachFile",
        "title": "MigraPilot: Attach File"
      },
      {
        "command": "migrapilot.cancelResponse",
        "title": "MigraPilot: Cancel Response"
      },
      {
        "command": "migrapilot.reviewProposedEdit",
        "title": "MigraPilot: Review Proposed Edit"
      },
      {
        "command": "migrapilot.approveProposedEdit",
        "title": "MigraPilot: Approve Proposed Edit"
      },
      {
        "command": "migrapilot.rejectProposedEdit",
        "title": "MigraPilot: Reject Proposed Edit"
      },
      {
        "command": "migrapilot.applyProposedEdit",
        "title": "MigraPilot: Apply Proposed Edit"
      },
      {
        "command": "migrapilot.rollbackProposedEdit",
        "title": "MigraPilot: Roll Back Proposed Edit"
      },
      {
        "command": "migrapilot.history",
        "title": "MigraPilot: Conversation History",
        "category": "MigraPilot"
      },
      {
        "command": "migrapilot.conversationState",
        "title": "MigraPilot: Show Conversation State (diagnostic)",
        "category": "MigraPilot"
      },
      {
        "command": "migrapilot.conversations.refresh",
        "title": "Refresh Conversations",
        "category": "MigraPilot",
        "icon": "$(refresh)"
      },
      {
        "command": "migrapilot.conversations.search",
        "title": "Search Conversations",
        "category": "MigraPilot",
        "icon": "$(search)"
      },
      {
        "command": "migrapilot.conversations.clearSearch",
        "title": "Clear Conversation Search",
        "category": "MigraPilot",
        "icon": "$(clear-all)"
      },
      {
        "command": "migrapilot.conversations.pin",
        "title": "Pin Conversation",
        "category": "MigraPilot",
        "icon": "$(pin)"
      },
      {
        "command": "migrapilot.conversations.unpin",
        "title": "Unpin Conversation",
        "category": "MigraPilot",
        "icon": "$(pinned)"
      },
      {
        "command": "migrapilot.conversations.rename",
        "title": "Rename Conversation",
        "category": "MigraPilot",
        "icon": "$(edit)"
      },
      {
        "command": "migrapilot.conversations.delete",
        "title": "Delete Conversation",
        "category": "MigraPilot",
        "icon": "$(trash)"
      },
      {
        "command": "migrapilot.resumeConversation",
        "title": "Resume Conversation",
        "category": "MigraPilot"
      }
    ],
    "configuration": {
      "title": "MigraPilot",
      "properties": {
        "migrapilot.backend": {
          "type": "string",
          "enum": [
            "pilot-web",
            "pilot-api"
          ],
          "enumDescriptions": [
            "Simple local Ollama engine (:3399) \u2014 read-only tools, in-memory.",
            "Full engine (:3377) \u2014 multi-provider model routing, missions, cryptographic approvals, durable state."
          ],
          "default": "pilot-api",
          "description": "Which MigraPilot backend the chat talks to. Default is the canonical pilot-api (full engine). 'pilot-web' is an explicit temporary fallback only."
        },
        "migrapilot.pilotApiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3377",
          "description": "Base URL of the full pilot-api backend (used when migrapilot.backend = pilot-api)."
        },
        "migrapilot.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3399",
          "description": "Base URL of the pilot-web backend (used when migrapilot.backend = pilot-web). Also serves the voice recorder page."
        },
        "migrapilot.apiToken": {
          "type": "string",
          "default": "",
          "description": "Optional bearer token for the pilot-api backend."
        },
        "migrapilot.ollamaUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama base URL used to list selectable models."
        },
        "migrapilot.visionModel": {
          "type": "string",
          "default": "llava:latest",
          "description": "Local Ollama vision model used to analyze attached images/screenshots (e.g. llava:latest, llama3.2-vision:11b)."
        },
        "migrapilot.workspace.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Let MigraPilot read and act on THIS workspace. Without it, pilot-api's repo/git tools run against the server's filesystem, where your files do not exist \u2014 so the assistant cannot actually see your code. Reads are automatic; writes always show a diff first; shell commands follow the auto-run list below."
        },
        "migrapilot.workspace.autoRunCommands": {
          "type": "boolean",
          "default": true,
          "description": "Run known build/test/lint commands (npm test, tsc --noEmit, eslint, read-only git) without asking, so MigraPilot can run your tests, read the failure and fix it. Anything not on that list \u2014 and anything that chains, redirects or substitutes commands \u2014 always asks. Turn this off to be prompted for every command."
        },
        "migrapilot.execution.live": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Off by default, and it should stay off unless you mean it.**\n\nWhen off, MigraPilot runs in dry-run: it can inspect, plan and propose, but no infrastructure is provisioned, no DNS is written, and nothing is deployed.\n\nWhen **on**, a mutating tool does not just run \u2014 it **stops and asks you**. You get an approval card showing the exact action (tool, real arguments, tenant, LIVE), and nothing happens until you click Approve. The approval is bound to that one action, is single-use, and is revalidated against policy at the moment it executes. It is not a session grant.\n\nCode changes are unaffected: they always go through the proposed-edit review, never this."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "migrapilot.conversations.search",
          "when": "view == migrapilot.conversations",
          "group": "navigation@1"
        },
        {
          "command": "migrapilot.conversations.clearSearch",
          "when": "view == migrapilot.conversations",
          "group": "navigation@2"
        },
        {
          "command": "migrapilot.conversations.refresh",
          "when": "view == migrapilot.conversations",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "migrapilot.conversations.pin",
          "when": "view == migrapilot.conversations && viewItem == migrapilot.conversation",
          "group": "inline@1"
        },
        {
          "command": "migrapilot.conversations.unpin",
          "when": "view == migrapilot.conversations && viewItem == migrapilot.conversation.pinned",
          "group": "inline@1"
        },
        {
          "command": "migrapilot.conversations.rename",
          "when": "view == migrapilot.conversations && viewItem =~ /migrapilot.conversation/",
          "group": "1_modify@1"
        },
        {
          "command": "migrapilot.conversations.delete",
          "when": "view == migrapilot.conversations && viewItem =~ /migrapilot.conversation/",
          "group": "9_danger@1"
        }
      ],
      "commandPalette": [
        {
          "command": "migrapilot.resumeConversation",
          "when": "false"
        },
        {
          "command": "migrapilot.conversations.pin",
          "when": "false"
        },
        {
          "command": "migrapilot.conversations.unpin",
          "when": "false"
        },
        {
          "command": "migrapilot.conversations.rename",
          "when": "false"
        },
        {
          "command": "migrapilot.conversations.delete",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "migrapilot.conversations",
        "contents": "No conversations yet.\\n\\nAsk MigraPilot something and it will appear here \u2014 every thread is stored and resumable.\\n[Open MigraPilot](command:migrapilot.openChat)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc -p ./ --noEmit",
    "test": "vitest run",
    "test:client": "vitest run test/client",
    "test:context": "vitest run test/context",
    "test:smoke": "vitest run test/smoke",
    "test:all": "vitest run",
    "test:integration": "tsc -p tsconfig.integration.json && node out-int/test/integration/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.18.34",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^10.5.0",
    "mocha": "^10.8.2",
    "typescript": "^5.1.6",
    "vitest": "^2.1.9"
  }
}
