{
  "name": "migrapilot-vscode",
  "displayName": "MigraPilot AI Engineer",
  "description": "AI engineering command center with reliable local context capture for the MigraTeck ecosystem.",
  "version": "0.0.3-ctx.1",
  "publisher": "migrateck",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./out/extension.js",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:migrapilot.chatView",
    "onCommand:migrapilot.openChat",
    "onCommand:migrapilot.explainCurrentFile",
    "onCommand:migrapilot.reviewSelection",
    "onCommand:migrapilot.startAgentTask",
    "onCommand:migrapilot.openVoiceCommand",
    "onCommand:migrapilot.openCommandCenter",
    "onCommand:migrapilot.showCurrentContext",
    "onCommand:migrapilot.captureCurrentContext"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "migrapilot",
          "title": "MigraPilot",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "migrapilot": [
        {
          "id": "migrapilot.chatView",
          "name": "AI Engineer",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "migrapilot.openChat",
        "title": "MigraPilot: Open Chat"
      },
      {
        "command": "migrapilot.explainCurrentFile",
        "title": "MigraPilot: Explain Current File"
      },
      {
        "command": "migrapilot.reviewSelection",
        "title": "MigraPilot: Review Selection"
      },
      {
        "command": "migrapilot.startAgentTask",
        "title": "MigraPilot: Start Agent Task"
      },
      {
        "command": "migrapilot.openVoiceCommand",
        "title": "MigraPilot: Open Voice Command"
      },
      {
        "command": "migrapilot.openCommandCenter",
        "title": "MigraPilot: Open Command Center"
      },
      {
        "command": "migrapilot.showCurrentContext",
        "title": "MigraPilot: Show Current Context"
      },
      {
        "command": "migrapilot.captureCurrentContext",
        "title": "MigraPilot: Capture Current Context"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.18.34",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.1.6"
  }
}
